---
import Icons from "./Icons.astro";
---
<section class="newsletter" id="newsletter">
  <div class="newsletter-emoji"><Icons name="mail" /></div>
  <h3>The Daily Briefing</h3>
  <p>UK medical cannabis news, global policy, and industry analysis — straight to your inbox.</p>
  <form class="newsletter-form" action="https://buttondown.com/api/emails/embed-subscribe/theganjaclub" method="post" target="_blank">
    <input type="email" name="email" placeholder="your@email.com" required />
    <button type="submit">Subscribe</button>
  </form>
</section>
