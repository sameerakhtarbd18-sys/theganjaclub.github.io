---
import Icons from "./Icons.astro";
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-grid">
      <!-- Brand -->
      <div class="footer-brand">
        <a href="/" class="footer-monogram" aria-label="The Ganja Club home">
          <img src="/logo-mark.svg" alt="TGC" width="32" height="32" loading="lazy" />
          <span class="footer-wordmark">The Ganja Club</span>
        </a>
        <p class="footer-tagline">
          Independent UK medical cannabis publication. Science-led, patient-first.
        </p>
        <div class="footer-social">
          <a href="https://instagram.com/theganjaclub_" target="_blank" rel="noopener" aria-label="Instagram">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
          <a href="https://x.com/theganjaclub_" target="_blank" rel="noopener" aria-label="X / Twitter">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a href="/rss" aria-label="RSS Feed">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 11a9 9 0 0 1 9 9"/>
              <path d="M4 4a16 16 0 0 1 16 16"/>
              <circle cx="5" cy="19" r="1"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Regions -->
      <div class="footer-col">
        <h4>Regions</h4>
        <a href="/uk">United Kingdom</a>
        <a href="/europe">Europe</a>
        <a href="/usa">United States</a>
        <a href="/global">Global</a>
        <a href="/research">Research</a>
      </div>

      <!-- Tools -->
      <div class="footer-col">
        <h4>Tools</h4>
        <a href="/eligibility">Eligibility Checker</a>
        <a href="/clinics">Compare Clinics</a>
        <a href="/strains">Strain Explorer</a>
      </div>

      <!-- Guides -->
      <div class="footer-col">
        <h4>Guides</h4>
        <a href="/guides/patient-rights">Patient Rights</a>
        <a href="/guides/getting-started">Getting Started</a>
        <a href="/guides/using-cannabis">Using Cannabis</a>
        <a href="/guides/strains-terpenes">Strains &amp; Terpenes</a>
        <a href="/plant-anatomy">Plant Anatomy</a>
      </div>

      <!-- About -->
      <div class="footer-col">
        <h4>About</h4>
        <a href="/resources">Resources</a>
        <a href="/shop">Shop</a>
        <a href="/rss">RSS Feed</a>
        <a href="mailto:contact@apcollective.ltd">Contact</a>
      </div>
    </div>

    <div class="footer-legal">
      <p class="footer-disclaimer">
        <strong>Medical disclaimer:</strong> The Ganja Club is an informational publication, not a medical provider. Nothing on this site constitutes medical advice. Always consult a GMC-registered specialist. Medical cannabis has been legal on prescription in the UK since November 2018.
      </p>
    </div>

    <div class="footer-bottom">
      <span>&copy; {year} The Ganja Club</span>
      <span>Part of AP Collective Ltd &middot; Bradford, UK</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--green-house);
    color: var(--text-on-dark);
    margin-top: auto;
  }
  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 64px 24px 32px;
  }

  /* ── Grid ── */
  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr repeat(4, 1fr);
    gap: 36px;
    margin-bottom: 40px;
  }

  /* ── Brand ── */
  .footer-monogram {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    margin-bottom: 14px;
  }
  .footer-monogram img {
    width: 28px;
    height: 28px;
    flex-shrink: 0;
  }
  .footer-wordmark {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text-on-dark);
    letter-spacing: -0.01em;
  }
  .footer-tagline {
    font-size: 0.85rem;
    line-height: 1.6;
    color: rgba(212,233,226,0.6);
    margin-bottom: 20px;
    max-width: 280px;
  }
  .footer-social {
    display: flex;
    gap: 10px;
  }
  .footer-social a {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.14);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(212,233,226,0.55);
    transition: all 0.2s ease;
  }
  .footer-social a:hover {
    border-color: var(--gold);
    color: var(--gold);
    transform: translateY(-1px);
  }

  /* ── Link columns ── */
  .footer-col h4 {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--gold);
    margin-bottom: 14px;
  }
  .footer-col a {
    display: block;
    font-size: 0.85rem;
    color: rgba(212,233,226,0.55);
    text-decoration: none;
    padding: 3px 0;
    transition: color 0.15s ease;
  }
  .footer-col a:hover {
    color: var(--text-on-dark);
  }

  /* ── Legal ── */
  .footer-legal {
    border-top: 1px solid rgba(255,255,255,0.08);
    padding-top: 24px;
    margin-bottom: 24px;
  }
  .footer-disclaimer {
    font-size: 0.75rem;
    line-height: 1.6;
    color: rgba(212,233,226,0.35);
    max-width: 720px;
    margin: 0;
  }

  /* ── Bottom bar ── */
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px;
    font-size: 0.75rem;
    color: rgba(212,233,226,0.3);
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 28px 24px;
    }
    .footer-grid > .footer-brand {
      grid-column: 1 / -1;
    }
    .footer-tagline {
      max-width: 100%;
    }
  }
  @media (max-width: 480px) {
    .footer-inner {
      padding: 48px 20px 24px;
    }
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 24px 16px;
    }
    .footer-bottom {
      flex-direction: column;
      text-align: center;
      gap: 4px;
    }
  }
</style>
