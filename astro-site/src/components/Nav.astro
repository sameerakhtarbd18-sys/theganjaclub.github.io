---
import Icons from "./Icons.astro";
const currentPath = Astro.url.pathname;
function isActive(path: string) {
  if (path === '/') return currentPath === '/';
  return currentPath.startsWith(path);
}
function isNews() {
  return isActive('/uk') || isActive('/europe') || isActive('/usa') || isActive('/global') || isActive('/research');
}
function isGuides() {
  return isActive('/guides');
}
---

<nav class="site-nav">
  <div class="nav-inner">
    <a href="/" class="nav-brand" aria-label="The Ganja Club home">
      <span class="brand-wordmark">The Ganja Club</span>
    </a>

    <button class="nav-hamburger" id="nav-hamburger" aria-label="Menu" aria-expanded="false">
      <span class="hamburger-icon"><Icons name="hamburger" /></span>
    </button>

    <div class="nav-links" id="nav-links">
      <!-- News dropdown -->
      <div class="nav-dropdown" data-dropdown>
        <button class="nav-dropdown-toggle" data-dropdown-toggle aria-haspopup="true" aria-expanded="false">
          News
          <span class="caret" aria-hidden="true"><Icons name="chevron-down" /></span>
        </button>
        <div class="nav-dropdown-menu" data-dropdown-menu>
          <a href="/" class:list={["dropdown-item", { active: isActive('/') && !isNews() }]}>Latest</a>
          <a href="/uk" class:list={["dropdown-item", { active: isActive('/uk') }]}>UK</a>
          <a href="/europe" class:list={["dropdown-item", { active: isActive('/europe') }]}>Europe</a>
          <a href="/usa" class:list={["dropdown-item", { active: isActive('/usa') }]}>USA</a>
          <a href="/global" class:list={["dropdown-item", { active: isActive('/global') }]}>Global</a>
          <a href="/research" class:list={["dropdown-item", { active: isActive('/research') }]}>Research</a>
        </div>
      </div>

      <!-- Guides dropdown -->
      <div class="nav-dropdown" data-dropdown>
        <button class="nav-dropdown-toggle" data-dropdown-toggle aria-haspopup="true" aria-expanded="false">
          Guides
          <span class="caret" aria-hidden="true"><Icons name="chevron-down" /></span>
        </button>
        <div class="nav-dropdown-menu" data-dropdown-menu>
          <a href="/guides" class:list={["dropdown-item", { active: currentPath === '/guides' }]}>All Guides</a>
          <a href="/guides/patient-rights" class:list={["dropdown-item", { active: isActive('/guides/patient-rights') }]}>Patient Rights</a>
          <a href="/guides/getting-started" class:list={["dropdown-item", { active: isActive('/guides/getting-started') }]}>Getting Started</a>
          <a href="/guides/using-cannabis" class:list={["dropdown-item", { active: isActive('/guides/using-cannabis') }]}>Using Cannabis</a>
          <a href="/guides/strains-terpenes" class:list={["dropdown-item", { active: isActive('/guides/strains-terpenes') }]}>Strains &amp; Terpenes</a>
        </div>
      </div>

      <!-- Tools dropdown -->
      <div class="nav-dropdown" data-dropdown>
        <button class="nav-dropdown-toggle" data-dropdown-toggle aria-haspopup="true" aria-expanded="false">
          Tools
          <span class="caret" aria-hidden="true"><Icons name="chevron-down" /></span>
        </button>
        <div class="nav-dropdown-menu" data-dropdown-menu>
          <a href="/clinics" class:list={["dropdown-item", { active: isActive('/clinics') }]}>Compare Clinics</a>
          <a href="/strains" class:list={["dropdown-item", { active: isActive('/strains') }]}>Strain Explorer</a>
          <a href="/eligibility" class:list={["dropdown-item", { active: isActive('/eligibility') }]}>Eligibility Checker</a>
        </div>
      </div>

      <!-- Direct links -->
      <a href="/resources" class:list={["nav-item", { active: isActive('/resources') }]}>Resources</a>

      <!-- Shop CTA pill -->
      <a href="/shop" class:list={["nav-item", "shop-pill", { active: isActive('/shop') }]}>Shop</a>

      <!-- RSS -->
      <a href="/rss" class:list={["nav-item", { active: isActive('/rss') }]}>RSS</a>

      <!-- Search button -->
      <button class="nav-search-btn" id="nav-search-btn" aria-label="Search articles">
        <Icons name="search" />
      </button>

      <!-- Dark mode toggle -->
      <button id="theme-toggle" aria-label="Toggle dark mode">
        <Icons name="dark-mode" />
      </button>
    </div>
  </div>
</nav>

<script is:inline>
  function initNavDropdowns() {
    const dropdowns = Array.from(document.querySelectorAll('[data-dropdown]'));
    if (!dropdowns.length) return;

    function closeAll(except) {
      dropdowns.forEach((d) => {
        if (d === except) return;
        d.classList.remove('open');
        const t = d.querySelector('[data-dropdown-toggle]');
        if (t) t.setAttribute('aria-expanded', 'false');
      });
    }

    dropdowns.forEach((d) => {
      const toggle = d.querySelector('[data-dropdown-toggle]');
      if (!toggle) return;
      
      function handleToggle(e) {
        e.preventDefault();
        e.stopPropagation();
        const willOpen = !d.classList.contains('open');
        closeAll(d);
        if (willOpen) {
          d.classList.add('open');
        } else {
          d.classList.remove('open');
        }
        toggle.setAttribute('aria-expanded', String(willOpen));
      }
      
      toggle.addEventListener('click', handleToggle);
      // Faster response on touch devices
      toggle.addEventListener('touchstart', handleToggle, {passive: false});
    });

    // Click outside closes everything
    document.addEventListener('click', (e) => {
      if (!e.target.closest('[data-dropdown]')) closeAll();
    });
    // Escape closes everything
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeAll();
    });
  }

  const hamburger = document.getElementById('nav-hamburger');
  const navLinks = document.getElementById('nav-links');
  if (hamburger && navLinks) {
    hamburger.addEventListener('click', () => {
      const isOpen = navLinks.classList.toggle('mobile-open');
      hamburger.setAttribute('aria-expanded', String(isOpen));
      const iconWrap = hamburger.querySelector('.hamburger-icon');
      if (iconWrap) {
        iconWrap.innerHTML = isOpen
          ? '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" role="img" aria-label="Close" style="color: var(--text)"><line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/></svg>'
          : '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" role="img" aria-label="Menu" style="color: var(--text)"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>';
      }
    });
  }

  // Run immediately — this script is inline, no DOMContentLoaded needed
  initNavDropdowns();
</script>
