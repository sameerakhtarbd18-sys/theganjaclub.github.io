---
export interface Props {
  title: string;
  slug: string;
  excerpt: string;
  image: string;
  tags: string[];
  date: string;
  readTime?: number;
}

const { title, slug, excerpt, image, tags, date, readTime = 3 } = Astro.props;
const kicker = (tags && tags.length > 0) ? tags[0] : "BRIEFING";
const siteUrl = "https://theganjaclub.netlify.app";
const imgSrc = image.startsWith("http") ? image : `${siteUrl}${image}`;
const formattedDate = new Date(date).toLocaleDateString("en-GB", {
  day: "numeric", month: "long", year: "numeric"
}).toUpperCase();
---

<article class="card">
  <a href={`/post/${slug}`} class="card-image" aria-hidden="true" tabindex="-1">
    <img src={imgSrc} alt="" loading="lazy" decoding="async" />
  </a>
  <div class="card-body">
    <div class="card-kicker">{kicker}</div>
    <h3 class="card-title">
      <a href={`/post/${slug}`}>{title}</a>
    </h3>
    <p class="card-excerpt">{excerpt}</p>
    <div class="card-meta">{formattedDate} · {readTime} MIN READ</div>
  </div>
</article>
