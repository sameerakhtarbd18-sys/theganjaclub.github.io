---
import { getCollection } from "astro:content";
import ArticleLayout from "../../layouts/ArticleLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map(p => ({ params: { slug: p.data.slug } }));
}

const { slug } = Astro.params;
const posts = await getCollection("posts");
const post = posts.find(p => p.data.slug === slug);

if (!post) {
  return Astro.redirect("/404");
}

const { title, date, region, excerpt, image, tags } = post.data;
const body = post.body || "";

/* Related posts: same region or shared tags, excluding current */
const related = posts
  .filter(p => p.data.slug !== slug)
  .filter(p =>
    p.data.region === region ||
    p.data.tags.some((t: string) => tags.includes(t))
  )
  .slice(0, 3)
  .map(p => ({
    title: p.data.title,
    slug: p.data.slug,
    excerpt: p.data.excerpt,
    image: p.data.image,
    tags: p.data.tags,
    date: p.data.date,
  }));
---

<ArticleLayout
  title={title}
  slug={slug!}
  date={date}
  region={region}
  excerpt={excerpt}
  image={image}
  tags={tags}
  body={body}
  related={related}
/>
