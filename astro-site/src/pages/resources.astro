---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import AffiliateBanner from "../components/AffiliateBanner.astro";
import Icons from "../components/Icons.astro";

const categories = [
  {
    heading: "Patient Organisations",
    items: [
      {
        title: "PLEA (Patient-Led Engagement for Access)",
        url: "https://pleacommunity.org.uk/",
        source: "pleacommunity.org.uk",
        description: "Community-led patient advocacy organisation working to improve medical cannabis access in the UK. Runs campaigns, publishes patient surveys, and engages with policymakers.",
      },
      {
        title: "Cancard",
        url: "https://www.cancard.co.uk/",
        source: "cancard.co.uk",
        description: "A patient verification card recognised by UK police forces. Provides identification for medical cannabis patients and supports advocacy for broader access. Free for eligible patients.",
      },
    ],
  },
  {
    heading: "Research & Data",
    items: [
      {
        title: "Drug Science — Project Twenty21",
        url: "https://www.drugscience.org.uk/project-twenty21/",
        source: "drugscience.org.uk",
        description: "The UK's largest medical cannabis patient registry, building the evidence base for NHS access while subsidising treatment for participating patients. Founded by Professor David Nutt.",
      },
      {
        title: "MedBud.wiki",
        url: "https://medbud.wiki/",
        source: "medbud.wiki",
        description: "The UK's most comprehensive medical cannabis resource. Search strains, compare clinics and pharmacies, access detailed patient guides, and join community forums. Independently run.",
      },
    ],
  },
  {
    heading: "Industry & Policy",
    items: [
      {
        title: "Smokie McGreen",
        url: "https://smokiemcgreen.com/",
        source: "smokiemcgreen.com",
        description: "Patient-focused education platform with terpene infographics, patient rights guides, clinic spotlights, and YouTube content. Plain English, no jargon.",
      },
      {
        title: "UK Medical Cannabis Clinics Directory",
        url: "https://medbud.wiki/clinics/",
        source: "medbud.wiki/clinics",
        description: "MedBud's impartial directory of every UK medical cannabis clinic — pricing, services, pharmacy partnerships, and patient reviews. The definitive starting point for choosing a clinic.",
      },
    ],
  },
  {
    heading: "Legal",
    items: [
      {
        title: "Release — Drug Law Charity",
        url: "https://www.release.org.uk/",
        source: "release.org.uk",
        description: "The UK's leading centre of expertise on drugs and drug law. Provides free legal advice, campaigns for drug policy reform, and publishes research on drug law enforcement.",
      },
      {
        title: "Transform Drug Policy",
        url: "https://transformdrugs.org/",
        source: "transformdrugs.org",
        description: "A think tank campaigning for the legal regulation of drugs. Publishes detailed policy briefs, international comparisons, and economic analyses of drug policy reform.",
      },
    ],
  },
];
---

<Base
  title="Resources — Medical Cannabis Links & Directories | The Ganja Club"
  description="Curated directory of trusted medical cannabis resources: patient organisations, research data, industry and policy, and legal support."
  ogImage="/images/flower/pexels-kindelmedia-7667912.webp"
>

<AffiliateBanner />
<Nav />

<main id="main-content">
  <header class="page-hero">
    <p class="kicker">Resources</p>
    <h1>Curated Cannabis Directory</h1>
    <p class="hero-sub">A hand-picked collection of the best resources, tools, and communities for UK medical cannabis patients. We've done the filtering so you don't have to.</p>
  </header>

  <div class="resources-container">
    {categories.map((cat) => (
      <section class="section">
        <h2 class="section-heading">{cat.heading}</h2>
        <div class="resource-grid">
          {cat.items.map((r) => (
            <a href={r.url} target="_blank" rel="noopener" class="resource-card">
              <div class="resource-header">
                <h3>{r.title}</h3>
                <Icons name="external" class="resource-ext-icon" />
              </div>
              <p class="resource-source">{r.source}</p>
              <p class="resource-desc">{r.description}</p>
              <span class="resource-cta">Visit site <Icons name="arrow-right" /></span>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>
</main>

<Footer />
</Base>

<style>
  .page-hero {
    text-align: center;
    padding: 64px 24px 48px;
    max-width: 720px;
    margin: 0 auto;
  }
  .kicker {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--green);
    margin-bottom: 12px;
  }
  .page-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    color: var(--text);
    line-height: 1.15;
    margin-bottom: 16px;
  }
  .hero-sub {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }
  .resources-container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 24px 64px;
  }
  .section {
    margin-bottom: 48px;
  }
  .section-heading {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 20px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--green);
    display: inline-block;
  }
  .resource-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--gap);
  }
  .resource-card {
    display: flex;
    flex-direction: column;
    padding: 24px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }
  .resource-card:hover {
    border-color: var(--green);
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }
  .resource-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
  }
  .resource-card h3 {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text);
  }
  .resource-ext-icon {
    flex-shrink: 0;
    margin-top: 4px;
  }
  .resource-source {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--green);
    text-transform: lowercase;
    margin: 6px 0 10px;
    letter-spacing: 0.02em;
  }
  .resource-desc {
    font-family: var(--font-body);
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--text-secondary);
    flex: 1;
  }
  .resource-cta {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--green);
    margin-top: 14px;
  }
  @media (min-width: 640px) {
    .resource-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
