---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const siteUrl = "https://theganjaclub.co.uk";

const parts = [
  {
    id: "trichomes",
    name: "Trichomes",
    icon: "💎",
    short: "Resin glands — where cannabinoids and terpenes live",
    body: "Trichomes are microscopic, mushroom-shaped glands that cover the surface of cannabis flowers and sugar leaves. They produce and store the plant's most valuable compounds: cannabinoids (THC, CBD, CBG) and terpenes (myrcene, limonene, pinene).\n\nUnder a microscope, trichomes look like tiny crystal mushrooms on stalks. Their colour signals ripeness: clear means immature, cloudy means peak potency, amber means degrading — this is how growers time their harvest.\n\nThere are three types: bulbous (smallest, scattered), capitate-sessile (medium, more common), and capitate-stalked (largest, most cannabinoid-rich — these are the ones that matter).",
    colour: "#C9A84C",
  },
  {
    id: "pistils",
    name: "Pistils",
    icon: "🧶",
    short: "The reproductive hairs that catch pollen",
    body: "Pistils are the hair-like structures that emerge from the calyx. Their job is to catch male pollen for fertilisation — but in cultivated cannabis (sinsemilla), the plant remains unfertilised, which means it directs energy into resin production instead of seed development.\n\nPistils start white and gradually darken to orange, red, or brown as the plant matures. This colour shift is a key harvest indicator: when 70-90% of pistils have darkened, the plant is typically ready.\n\nThey contain negligible cannabinoids — their value is in what they tell you about the plant's maturity, not what they contribute to the final product.",
    colour: "#E8815C",
  },
  {
    id: "calyx",
    name: "Calyx",
    icon: "🌿",
    short: "The flower's protective casing — where buds form",
    body: "The calyx is the tear-shaped base from which pistils emerge and the first part of the flower to form. It is the plant's reproductive organ — in an unfertilised plant, calyxes swell and stack on top of each other to create what we recognise as a cannabis bud.\n\nCalyxes house the plant's highest concentration of trichomes, making them the most potent part of the flower. When you see a dense, frosty bud, you are looking at layers of swollen calyxes covered in resin glands.\n\nIn trim, calyxes are what you want to keep — sugar leaves you trim away.",
    colour: "#059669",
  },
  {
    id: "sugar-leaves",
    name: "Sugar Leaves",
    icon: "🍃",
    short: "Small resin-coated leaves growing from the bud",
    body: "Sugar leaves are the small, trichome-covered leaves that grow directly from the flower. They get their name from the crystalline 'sugar' coating of resin glands visible to the naked eye.\n\nUnlike fan leaves (the large solar panels that power the plant), sugar leaves are trimmed closely during harvest. They are less potent than the calyx but still contain useful cannabinoids — most growers save sugar leaf trim for edibles, extracts, or hash.\n\nTheir purpose is structural: they protect the developing flower and provide additional surface area for trichome production.",
    colour: "#4ADE80",
  },
  {
    id: "stem",
    name: "Stem",
    icon: "🪵",
    short: "The vascular highway — water, nutrients, and structural support",
    body: "The stem is the plant's circulatory system. Xylem vessels carry water and dissolved minerals upward from the roots. Phloem vessels transport sugars and nutrients downward from the leaves.\n\nStems contain negligible cannabinoids and should be removed before consumption. Their value is purely structural — a plant with a weak stem cannot support heavy flowers.\n\nIn cultivation, stem thickness is a health indicator: thin, spindly stems suggest insufficient light or airflow. Thick, sturdy stems signal a well-fed plant ready to carry weight.",
    colour: "#78716C",
  },
  {
    id: "fan-leaves",
    name: "Fan Leaves",
    icon: "☀️",
    short: "The iconic cannabis leaf — the plant's solar panels",
    body: "Fan leaves are the large, iconic leaves with 5-11 pointed leaflets. They contain almost no cannabinoids — their job is photosynthesis: converting light, water, and CO₂ into the energy that fuels flower development.\n\nDuring flowering, growers often defoliate lower fan leaves to improve airflow and direct energy to bud sites. Yellowing fan leaves late in flower is normal — it signals the plant is drawing stored nutrients into the flowers.\n\nWhile not consumed, fan leaves are a reliable indicator of plant health. Curling, spotting, or discolouration each point to specific nutrient or environmental problems.",
    colour: "#22C55E",
  },
];
---

<Base
  title="Cannabis Plant Anatomy — Interactive Explorer | The Ganja Club"
  description="Explore the cannabis plant in detail: trichomes, pistils, calyx, sugar leaves. Hover and click to learn how each part contributes to the medicine."
  ogImage="/logo.svg"
>
  <Nav />

  <main id="main-content">
    <section class="plant-hero">
      <div class="plant-hero-inner">
        <p class="plant-kicker">INTERACTIVE</p>
        <h1 class="plant-title">Cannabis Plant Anatomy</h1>
        <p class="plant-subtitle">
          Hover over the bud to identify each part. Click for a deeper dive — what it does, why it matters, and how it contributes to the medicine.
        </p>
      </div>
    </section>

    <section class="plant-explorer">
      <div class="explorer-layout">
        <!-- SVG illustration -->
        <div class="explorer-visual" id="explorer-visual">
          <svg viewBox="0 0 500 600" xmlns="http://www.w3.org/2000/svg" class="bud-svg">
            <defs>
              <radialGradient id="bgGrad" cx="50%" cy="50%">
                <stop offset="0%" stop-color="#1a2e25"/>
                <stop offset="100%" stop-color="#0f1d18"/>
              </radialGradient>
              {/* Glow filter for hover states */}
              <filter id="glow">
                <feGaussianBlur stdDeviation="3" result="blur"/>
                <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
              </filter>
            </defs>

            <rect width="500" height="600" fill="url(#bgGrad)" rx="12"/>

            {/* Main stem */}
            <path id="stem-hit" d="M240 580 Q245 480 250 380 L250 280" stroke="#78716C" stroke-width="8" fill="none" stroke-linecap="round" class="part-interactive" style="cursor:pointer"/>
            <path d="M238 570 Q244 480 248 380 L248 280" stroke="#9A8C80" stroke-width="5" fill="none" stroke-linecap="round" class="part-path"/>

            {/* Fan leaves (background) */}
            <path d="M250 400 Q200 340 140 360 Q180 380 200 370 Q195 350 250 400" fill="#166534" opacity="0.6"/>
            <path d="M250 400 Q300 340 360 360 Q320 380 300 370 Q305 350 250 400" fill="#166534" opacity="0.6"/>
            <!-- Fan leaf veins -->
            <line x1="250" y1="400" x2="160" y2="362" stroke="#22C55E" stroke-width="0.8" opacity="0.4"/>
            <line x1="250" y1="400" x2="340" y2="362" stroke="#22C55E" stroke-width="0.8" opacity="0.4"/>

            {/* Lower fan leaf on hover zone */}
            <path id="fan-leaves-hit" d="M250 430 Q180 380 140 360 Q190 380 210 385 L250 430 M250 430 Q320 380 360 360 Q310 380 290 385 L250 430" fill="#22C55E" opacity="0.01" class="part-interactive" style="cursor:pointer"/>

            {/* Sugar leaves */}
            <path id="sugar-leaves-hit" d="M250 280 Q200 230 180 200 Q210 210 230 230 L250 280 M250 280 Q300 230 320 200 Q290 210 270 230 L250 280" fill="#4ADE80" opacity="0.01" class="part-interactive" style="cursor:pointer"/>
            <path d="M250 280 Q205 235 185 205 Q210 218 232 235 L250 280" fill="#166534" opacity="0.7" stroke="#4ADE80" stroke-width="0.5"/>
            <path d="M250 280 Q295 235 315 205 Q290 218 268 235 L250 280" fill="#166534" opacity="0.7" stroke="#4ADE80" stroke-width="0.5"/>

            {/* Main bud — layered calyxes */}
            <ellipse id="calyx-hit" cx="250" cy="240" rx="48" ry="65" fill="#059669" opacity="0.1" class="part-interactive" style="cursor:pointer"/>

            {/* Calyx cluster — individual shapes */}
            <ellipse cx="250" cy="210" rx="30" ry="22" fill="#047857" transform="rotate(-5 250 210)"/>
            <ellipse cx="265" cy="235" rx="25" ry="20" fill="#059669" transform="rotate(8 265 235)"/>
            <ellipse cx="235" cy="238" rx="24" ry="19" fill="#047857" transform="rotate(-8 235 238)"/>
            <ellipse cx="250" cy="255" rx="28" ry="20" fill="#059669" transform="rotate(3 250 255)"/>
            <ellipse cx="240" cy="225" rx="22" ry="18" fill="#047857" transform="rotate(-3 240 225)"/>
            <ellipse cx="260" cy="222" rx="22" ry="17" fill="#059669" transform="rotate(6 260 222)"/>

            {/* Trichomes — clustered dots */}
            <g class="trichome-dots" id="trichomes-hit">
              {/* Top cluster */}
              <circle cx="245" cy="200" r="2" fill="#C9A84C" opacity="0.9"/><circle cx="255" cy="198" r="1.8" fill="#C9A84C" opacity="0.85"/>
              <circle cx="238" cy="205" r="1.5" fill="#C9A84C" opacity="0.8"/><circle cx="262" cy="203" r="2" fill="#C9A84C" opacity="0.9"/>
              <circle cx="250" cy="195" r="2.2" fill="#D4AF37" opacity="0.95"/><circle cx="258" cy="208" r="1.5" fill="#C9A84C" opacity="0.75"/>
              {/* Mid cluster */}
              <circle cx="233" cy="225" r="1.8" fill="#C9A84C" opacity="0.85"/><circle cx="267" cy="228" r="2" fill="#C9A84C" opacity="0.9"/>
              <circle cx="248" cy="222" r="1.5" fill="#D4AF37" opacity="0.8"/><circle cx="260" cy="218" r="1.8" fill="#C9A84C" opacity="0.85"/>
              <circle cx="242" cy="235" r="2" fill="#D4AF37" opacity="0.9"/><circle cx="268" cy="240" r="1.5" fill="#C9A84C" opacity="0.75"/>
              {/* Lower cluster */}
              <circle cx="240" cy="250" r="1.8" fill="#C9A84C" opacity="0.8"/><circle cx="258" cy="248" r="1.5" fill="#D4AF37" opacity="0.85"/>
              <circle cx="250" cy="252" r="2" fill="#C9A84C" opacity="0.9"/><circle cx="245" cy="248" r="1.5" fill="#C9A84C" opacity="0.75"/>
              {/* Scattered */}
              <circle cx="225" cy="240" r="1.5" fill="#C9A84C" opacity="0.7"/><circle cx="275" cy="235" r="1.8" fill="#C9A84C" opacity="0.8"/>
              <circle cx="252" cy="260" r="1.5" fill="#D4AF37" opacity="0.7"/><circle cx="236" cy="258" r="1.2" fill="#C9A84C" opacity="0.65"/>
            </g>

            {/* Pistils — wavy orange hairs */}
            <g id="pistils-hit" class="part-interactive" style="cursor:pointer">
              <path d="M240 200 Q235 185 238 175" stroke="#E8815C" stroke-width="1.5" fill="none" stroke-linecap="round"/>
              <path d="M260 202 Q265 185 260 175" stroke="#E8815C" stroke-width="1.5" fill="none" stroke-linecap="round"/>
              <path d="M235 230 Q225 215 228 205" stroke="#E8815C" stroke-width="1.2" fill="none" stroke-linecap="round"/>
              <path d="M265 228 Q275 215 272 205" stroke="#E8815C" stroke-width="1.5" fill="none" stroke-linecap="round"/>
              <path d="M248 255 Q242 240 245 232" stroke="#E8815C" stroke-width="1.2" fill="none" stroke-linecap="round"/>
              <path d="M255 253 Q260 240 258 232" stroke="#E8815C" stroke-width="1.5" fill="none" stroke-linecap="round"/>
              <path d="M250 210 Q248 192 250 185" stroke="#E8815C" stroke-width="1.3" fill="none" stroke-linecap="round"/>
              <path d="M238 218 Q228 208 232 198" stroke="#E8815C" stroke-width="1.2" fill="none" stroke-linecap="round"/>
            </g>

            {/* Labels */}
            <text x="135" y="195" class="plant-label" id="label-trichomes">Trichomes</text>
            <line x1="160" y1="198" x2="230" y2="200" stroke="#C9A84C" stroke-width="0.8" stroke-dasharray="3 2" opacity="0.6"/>

            <text x="310" y="230" class="plant-label" id="label-pistils">Pistils</text>
            <line x1="305" y1="233" x2="275" y2="228" stroke="#E8815C" stroke-width="0.8" stroke-dasharray="3 2" opacity="0.6"/>

            <text x="310" y="255" class="plant-label" id="label-calyx">Calyx</text>
            <line x1="300" y1="258" x2="280" y2="250" stroke="#059669" stroke-width="0.8" stroke-dasharray="3 2" opacity="0.6"/>

            <text x="130" y="400" class="plant-label" id="label-fan-leaves">Fan Leaf</text>
            <line x1="200" y1="403" x2="180" y2="385" stroke="#22C55E" stroke-width="0.8" stroke-dasharray="3 2" opacity="0.6"/>
          </svg>
        </div>

        <!-- Info panel -->
        <div class="explorer-info" id="explorer-info">
          <div class="info-default">
            <span class="info-icon-large">🔬</span>
            <h2 class="info-title">Explore the bud</h2>
            <p class="info-hint">Hover over the illustration or tap a label to learn about each part of the cannabis flower.</p>
            <div class="info-quick-list">
              {parts.map((p) => (
                <button class="info-quick-btn" data-part={p.id} style={`--part-colour: ${p.colour}`}>
                  <span>{p.icon}</span> {p.name}
                </button>
              ))}
            </div>
          </div>

          {parts.map((p) => (
            <div class="info-detail" id={`detail-${p.id}`} style="display:none">
              <span class="info-icon-large">{p.icon}</span>
              <h2 class="info-title" style={`color: ${p.colour}`}>{p.name}</h2>
              <p class="info-short">{p.short}</p>
              <div class="info-body">
                {p.body.split("\n\n").map((para) => <p>{para}</p>)}
              </div>
              <button class="info-back-btn" data-part={p.id}>← Back to overview</button>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Bottom section -->
    <section class="plant-cta">
      <div class="plant-cta-inner">
        <h2>Why anatomy matters for patients</h2>
        <p>
          Understanding the difference between a trichome and a pistil isn't academic — it is practical. Trichome colour tells you when the plant was harvested. Calyx-to-leaf ratio tells you how well it was trimmed. Sugar leaf presence tells you how carefully it was handled. These are quality signals you can see with your own eyes.
        </p>
        <a href="/guides/strains-terpenes" class="plant-cta-btn">Read our strains & terpenes guide →</a>
      </div>
    </section>
  </main>

  <Footer />
</Base>

<script>
  const partData = [
    { id: "trichomes", name: "Trichomes", icon: "💎", short: "Resin glands — where cannabinoids and terpenes live", colour: "#C9A84C" },
    { id: "pistils", name: "Pistils", icon: "🧶", short: "The reproductive hairs that catch pollen", colour: "#E8815C" },
    { id: "calyx", name: "Calyx", icon: "🌿", short: "The flower's protective casing — where buds form", colour: "#059669" },
    { id: "sugar-leaves", name: "Sugar Leaves", icon: "🍃", short: "Small resin-coated leaves growing from the bud", colour: "#4ADE80" },
    { id: "stem", name: "Stem", icon: "🪵", short: "The vascular highway — water, nutrients, and structural support", colour: "#78716C" },
    { id: "fan-leaves", name: "Fan Leaves", icon: "☀️", short: "The iconic cannabis leaf — the plant's solar panels", colour: "#22C55E" },
  ];

  document.querySelectorAll(".part-interactive, .info-quick-btn").forEach((el) => {
    el.addEventListener("click", () => {
      const partId = el.dataset.part || el.id?.replace("-hit", "");
      if (!partId) return;
      showDetail(partId);
    });

    if (el.classList.contains("part-interactive")) {
      el.addEventListener("mouseenter", () => {
        const partId = el.id?.replace("-hit", "");
        const label = document.getElementById(`label-${partId}`);
        if (label) label.style.fontWeight = "700";
      });
      el.addEventListener("mouseleave", () => {
        const partId = el.id?.replace("-hit", "");
        const label = document.getElementById(`label-${partId}`);
        if (label) label.style.fontWeight = "500";
      });
    }
  });

  document.querySelectorAll(".info-back-btn").forEach((btn) => {
    btn.addEventListener("click", () => showDefault());
  });

  function showDetail(partId) {
    document.querySelector(".info-default")!.style.display = "none";
    document.querySelectorAll(".info-detail").forEach((d) => {
      (d as HTMLElement).style.display = "none";
    });
    const detail = document.getElementById(`detail-${partId}`);
    if (detail) (detail as HTMLElement).style.display = "block";
  }

  function showDefault() {
    document.querySelector(".info-default")!.style.display = "block";
    document.querySelectorAll(".info-detail").forEach((d) => {
      (d as HTMLElement).style.display = "none";
    });
  }
</script>

<style>
  .plant-hero {
    padding: 64px 24px 48px;
    background: var(--green-house);
    text-align: center;
  }
  .plant-hero-inner { max-width: 640px; margin: 0 auto; }
  .plant-kicker {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--gold);
    margin-bottom: 12px;
  }
  .plant-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    color: var(--text-on-dark);
    margin-bottom: 16px;
  }
  .plant-subtitle {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text-on-dark-soft);
  }

  .plant-explorer {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 48px 24px;
  }
  .explorer-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }

  .explorer-visual {
    display: flex;
    justify-content: center;
  }
  .bud-svg {
    width: 100%;
    max-width: 460px;
    height: auto;
  }

  .part-interactive {
    transition: opacity 0.2s ease;
  }
  .part-interactive:hover {
    opacity: 0.5;
    filter: url(#glow);
  }

  .trichome-dots {
    cursor: pointer;
  }
  .trichome-dots circle {
    transition: r 0.2s ease, opacity 0.2s ease;
  }
  .trichome-dots:hover circle {
    r: 2.5;
    opacity: 1;
  }

  .plant-label {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    fill: var(--text-on-dark);
    transition: font-weight 0.15s;
  }

  /* Info panel */
  .explorer-info {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 32px;
    min-height: 360px;
    box-shadow: var(--shadow);
  }
  .info-default, .info-detail {
    animation: fadeIn 0.25s ease;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .info-icon-large { font-size: 2.5rem; display: block; margin-bottom: 16px; }
  .info-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--text);
  }
  .info-hint {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: 24px;
  }
  .info-short {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-style: italic;
    color: var(--text-secondary);
    margin-bottom: 16px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }
  .info-body {
    font-family: var(--font-body);
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--text-secondary);
  }
  .info-body p { margin-bottom: 12px; }

  .info-quick-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .info-quick-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-body);
    font-size: 0.82rem;
    cursor: pointer;
    transition: all 0.15s ease;
  }
  .info-quick-btn:hover {
    border-color: var(--part-colour, var(--green));
    color: var(--part-colour, var(--green));
  }
  .info-back-btn {
    margin-top: 20px;
    padding: 8px 0;
    background: none;
    border: none;
    color: var(--green);
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
  }
  .info-back-btn:hover { text-decoration: underline; }

  /* CTA */
  .plant-cta {
    padding: 48px 24px 80px;
    background: var(--bg-elevated);
  }
  .plant-cta-inner {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
  }
  .plant-cta-inner h2 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--green);
    margin-bottom: 12px;
  }
  .plant-cta-inner p {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: 24px;
  }
  .plant-cta-btn {
    color: var(--green);
    font-weight: 600;
    font-family: var(--font-body);
  }

  @media (max-width: 800px) {
    .explorer-layout {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
