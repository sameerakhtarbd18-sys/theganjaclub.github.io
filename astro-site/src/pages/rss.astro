---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import AffiliateBanner from "../components/AffiliateBanner.astro";
import Icons from "../components/Icons.astro";
---

<Base
  title="RSS Feed — The Ganja Club"
  description="Subscribe to The Ganja Club via RSS for the latest medical cannabis news and analysis."
>

<AffiliateBanner />
<Nav />

<main id="main-content" class="rss-page">
  <div class="rss-icon"><Icons name="rss" /></div>
  <h1>RSS Feed</h1>
  <p style="color:var(--text-secondary);max-width:480px;margin:0 auto 0;">
    Subscribe to The Ganja Club and get every new article delivered to your feed reader.
  </p>

  <div class="rss-options">
    <div class="rss-option">
      <h3>Direct Feed URL</h3>
      <p>Copy this URL into any RSS reader</p>
      <div class="rss-url" id="rss-url">https://theganjaclub.co.uk/rss.xml</div>
    </div>
    <div class="rss-option">
      <h3>Popular Readers</h3>
      <p>Open directly in your preferred app</p>
      <div style="display:flex;flex-direction:column;gap:8px;align-items:center;">
        <a href="https://feedly.com/i/subscription/feed/https://theganjaclub.co.uk/rss.xml" target="_blank" rel="noopener" class="share-btn" style="background:#2bb24c;width:200px;">Feedly</a>
        <a href="https://www.inoreader.com/?add_feed=https://theganjaclub.co.uk/rss.xml" target="_blank" rel="noopener" class="share-btn" style="background:#1a73e8;width:200px;">Inoreader</a>
        <a href="https://theganjaclub.co.uk/rss.xml" class="share-btn" style="background:var(--bg-card);color:var(--text)!important;border:1px solid var(--border);width:200px;">Raw XML</a>
      </div>
    </div>
  </div>

  <p style="font-size:0.85rem;color:var(--text-muted);margin-top:32px;">
    New to RSS? <a href="https://aboutfeeds.com" target="_blank" rel="noopener">Learn how to get started <Icons name="arrow-right" /></a>
  </p>
</main>

<Footer />

</Base>
