---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import AffiliateBanner from "../components/AffiliateBanner.astro";
import Icons from "../components/Icons.astro";
---

<Base
  title="RSS Feed — The Ganja Club"
  description="Subscribe to The Ganja Club via RSS for the latest medical cannabis news and analysis."
>

<AffiliateBanner />
<Nav />

<main id="main-content" class="rss-page">
  <header class="page-hero">
    <div class="rss-hero-icon"><Icons name="rss" /></div>
    <h1>RSS Feed</h1>
    <p class="hero-sub">
      Subscribe to The Ganja Club and get every new article delivered to your feed reader automatically — no algorithms, no email clutter, just our latest coverage as it's published.
    </p>
  </header>

  <section class="rss-section">
    <div class="rss-content">
      <h2 class="section-heading">What is RSS?</h2>
      <p class="rss-explainer">
        RSS (Really Simple Syndication) is a standardised web feed format that lets you subscribe to websites and receive new content in a feed reader. Instead of checking back manually or relying on social media algorithms, your reader collects new articles for you — like a personalised inbox for the web.
      </p>

      <h2 class="section-heading">Feed URL</h2>
      <p class="rss-explainer">Copy this URL into any RSS reader to subscribe:</p>
      <div class="rss-code-block">
        <code id="rss-url">https://theganjaclub.co.uk/rss.xml</code>
        <button class="rss-copy-btn" id="rss-copy-btn" aria-label="Copy feed URL">
          <Icons name="copy" />
        </button>
      </div>

      <h2 class="section-heading">Popular RSS Readers</h2>
      <div class="rss-readers-grid">
        <a href="https://feedly.com/i/subscription/feed/https://theganjaclub.co.uk/rss.xml" target="_blank" rel="noopener" class="reader-card">
          <div class="reader-name">Feedly</div>
          <div class="reader-desc">Web, iOS, Android. The most popular RSS reader with AI-powered recommendations.</div>
          <span class="reader-link">Open in Feedly <Icons name="arrow-right" /></span>
        </a>
        <a href="https://netnewswire.com/" target="_blank" rel="noopener" class="reader-card">
          <div class="reader-name">NetNewsWire</div>
          <div class="reader-desc">Free, open-source reader for Mac and iOS. Fast, clean, and privacy-focused.</div>
          <span class="reader-link">Visit NetNewsWire <Icons name="arrow-right" /></span>
        </a>
        <a href="https://www.inoreader.com/?add_feed=https://theganjaclub.co.uk/rss.xml" target="_blank" rel="noopener" class="reader-card">
          <div class="reader-name">Inoreader</div>
          <div class="reader-desc">Web-based reader with powerful filtering, rules, and automation features.</div>
          <span class="reader-link">Open in Inoreader <Icons name="arrow-right" /></span>
        </a>
      </div>

      <p class="rss-footnote">
        New to RSS? <a href="https://aboutfeeds.com" target="_blank" rel="noopener">Learn how to get started <Icons name="arrow-right" /></a>
      </p>
    </div>
  </section>
</main>

<Footer />
</Base>

<script>
  const copyBtn = document.getElementById('rss-copy-btn');
  const rssUrl = document.getElementById('rss-url');
  if (copyBtn && rssUrl) {
    copyBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(rssUrl.textContent || '');
        copyBtn.classList.add('copied');
        setTimeout(() => copyBtn.classList.remove('copied'), 2000);
      } catch {
        /* Clipboard API unavailable */
      }
    });
  }
</script>

<style>
  .rss-page {
    max-width: var(--max-width);
    margin: 0 auto;
  }
  .page-hero {
    text-align: center;
    padding: 64px 24px 40px;
    max-width: 640px;
    margin: 0 auto;
  }
  .rss-hero-icon {
    color: var(--green) !important;
    margin-bottom: 20px;
    display: flex;
    justify-content: center;
  }
  .rss-hero-icon :global(svg) {
    width: 48px !important;
    height: 48px !important;
    color: var(--green) !important;
  }
  .page-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    color: var(--text);
    line-height: 1.15;
    margin-bottom: 16px;
  }
  .hero-sub {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--text-secondary);
  }
  .rss-section {
    padding: 0 24px 64px;
    max-width: 720px;
    margin: 0 auto;
  }
  .section-heading {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--text);
    margin: 40px 0 16px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--green);
    display: inline-block;
  }
  .rss-explainer {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--text-secondary);
    margin-bottom: 8px;
  }
  .rss-code-block {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 16px 0 8px;
    padding: 16px 20px;
    background: var(--green-house);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .rss-code-block code {
    font-family: 'SF Mono', 'Monaco', 'Cascadia Code', monospace;
    font-size: 0.9rem;
    color: var(--text-on-dark);
    flex: 1;
    word-break: break-all;
  }
  .rss-copy-btn {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border-radius: var(--radius);
    border: 1px solid rgba(212, 233, 226, 0.2);
    background: rgba(255, 255, 255, 0.06);
    color: var(--text-on-dark-soft);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  .rss-copy-btn:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: var(--gold);
  }
  .rss-copy-btn.copied {
    background: var(--green-accent);
    border-color: var(--green-accent);
  }
  .rss-readers-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--gap);
    margin-top: 20px;
  }
  .reader-card {
    display: flex;
    flex-direction: column;
    padding: 24px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }
  .reader-card:hover {
    border-color: var(--green);
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }
  .reader-name {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 6px;
  }
  .reader-desc {
    font-family: var(--font-body);
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--text-secondary);
    flex: 1;
    margin-bottom: 12px;
  }
  .reader-link {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--green);
  }
  .rss-footnote {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-top: 32px;
    text-align: center;
  }
  .rss-footnote a {
    color: var(--green-accent);
    text-decoration: none;
  }
  @media (min-width: 640px) {
    .rss-readers-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
