---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Newsletter from "../components/Newsletter.astro";
import Icons from "../components/Icons.astro";
import clinicData from "../data/clinics.json";
import priceHistory from "../data/price-history.json";

const { clinics, lastReviewed, disclaimer } = clinicData;
const siteUrl = "https://theganjaclub.co.uk";

// Inline SVG line chart for the price tracker (no chart library — site stays lightweight)
const series = priceHistory.series;
const W = 640, H = 220, PAD = 36;
const fees = series.map(s => s.avgInitialFee);
const maxFee = Math.max(...fees) * 1.15;
const px = (i: number) => PAD + (i * (W - PAD * 2)) / (series.length - 1);
const py = (v: number) => H - PAD - (v / maxFee) * (H - PAD * 2);
const linePath = series.map((s, i) => `${i === 0 ? "M" : "L"}${px(i)},${py(s.avgInitialFee)}`).join(" ");

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Compare UK Medical Cannabis Clinics",
  description: "Independent comparison of UK medical cannabis clinic fees, models and onboarding speed.",
  url: `${siteUrl}/clinics`,
};
---

<Base
  title="Compare UK Medical Cannabis Clinics — Fees & Models | The Ganja Club"
  description="Independent comparison of UK medical cannabis clinics: consultation fees, ongoing costs, onboarding speed and care models. Updated quarterly."
  canonicalUrl={`${siteUrl}/clinics`}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} is:inline />
  <Nav />

  <main class="tool-page">
    <header class="tool-header">
      <p class="kicker">PATIENT TOOLS</p>
      <h1>Compare UK Medical Cannabis Clinics</h1>
      <p class="lede">
        Every major UK clinic, side by side: what the first appointment costs, what you pay ongoing,
        and which care model fits how you want to be looked after. Last reviewed
        <strong>{new Date(lastReviewed).toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" })}</strong>.
      </p>
    </header>

    <div class="filter-bar" id="clinic-filters">
      <button class="pill active" data-model="all">All models</button>
      <button class="pill" data-model="Pay-as-you-go">Pay-as-you-go</button>
      <button class="pill" data-model="Subscription (all-inclusive)">Subscription</button>
      <button class="pill" data-model="Zero-fee">Zero-fee</button>
      <span class="sort-wrap">
        <label for="clinic-sort">Sort:</label>
        <select id="clinic-sort">
          <option value="initial">Initial fee (low to high)</option>
          <option value="name">Name (A–Z)</option>
        </select>
      </span>
    </div>

    <div class="clinic-grid" id="clinic-grid">
      {clinics.map(c => (
        <article
          class="clinic-card"
          data-model={c.model}
          data-initial={c.initialFee === null ? 99999 : c.initialFee}
          data-name={c.name}
        >
          <div class="clinic-top">
            <h2>{c.name}</h2>
            {c.verified
              ? <span class="badge badge-verified">Verified {new Date(lastReviewed).toLocaleDateString("en-GB", { month: "short", year: "numeric" })}</span>
              : <span class="badge badge-unverified">Unverified — confirm with clinic</span>}
          </div>
          <p class="model">{c.model} · <em>{c.bestFor}</em></p>
          <div class="fee-row">
            <div class="fee">
              <span class="fee-label">INITIAL</span>
              <span class="fee-value">{c.initialFee === null ? "—" : c.initialFee === 0 ? "Free" : `£${c.initialFee}`}</span>
            </div>
            <div class="fee">
              <span class="fee-label">FOLLOW-UP</span>
              <span class="fee-value">{c.followUpFee === null ? "—" : c.followUpFee === 0 ? "Free" : `£${c.followUpFee}`}</span>
            </div>
            {c.trustpilot && (
              <div class="fee">
                <span class="fee-label">TRUSTPILOT</span>
                <span class="fee-value">{c.trustpilot}★</span>
              </div>
            )}
          </div>
          <p class="note">{c.ongoingNote}</p>
          {c.speedNote && <p class="note speed">{c.speedNote}</p>}
          <p class="conditions">{c.conditions.join(" · ")}</p>
          <a class="clinic-link" href={c.url} target="_blank" rel="noopener nofollow">Visit clinic <Icons name="arrow-right" /></a>
        </article>
      ))}
    </div>

    <section class="tracker">
      <h2>Clinic Price Tracker</h2>
      <p class="lede small">
        Average initial consultation fee across major UK clinics, by quarter. {priceHistory.note}
      </p>
      <svg viewBox={`0 0 ${W} ${H}`} role="img" aria-label="Average initial consultation fee by quarter">
        <line x1={PAD} y1={H - PAD} x2={W - PAD} y2={H - PAD} class="axis" />
        <path d={linePath} class="trend" />
        {series.map((s, i) => (
          <>
            <circle cx={px(i)} cy={py(s.avgInitialFee)} r="5" class="dot" />
            <text x={px(i)} y={py(s.avgInitialFee) - 12} text-anchor="middle" class="val">£{s.avgInitialFee}</text>
            <text x={px(i)} y={H - PAD + 22} text-anchor="middle" class="lab">{s.quarter}</text>
          </>
        ))}
      </svg>
      <p class="note">Average flower price currently runs roughly £{series[series.length - 1].avgFlowerPerGram}/g across major pharmacies, with budget products lower and premium cultivars above £12/g.</p>
    </section>

    <section class="disclaimer-band">
      <p><strong>About this data:</strong> {disclaimer} The Ganja Club is an independent publication — clinics do not pay for placement, and order is set by your chosen sort.</p>
      <p>This page is general information, not medical or financial advice. Eligibility and product decisions rest with a GMC-registered specialist clinician.</p>
    </section>

    <Newsletter />
  </main>

  <Footer />
</Base>

<script>
  const grid = document.getElementById("clinic-grid")!;
  const cards = Array.from(grid.querySelectorAll<HTMLElement>(".clinic-card"));
  const pills = document.querySelectorAll<HTMLButtonElement>("#clinic-filters .pill");
  const sortSel = document.getElementById("clinic-sort") as HTMLSelectElement;

  function apply() {
    const model = document.querySelector<HTMLButtonElement>("#clinic-filters .pill.active")!.dataset.model!;
    const sorted = [...cards].sort((a, b) =>
      sortSel.value === "initial"
        ? Number(a.dataset.initial) - Number(b.dataset.initial)
        : a.dataset.name!.localeCompare(b.dataset.name!)
    );
    sorted.forEach(c => {
      grid.appendChild(c);
      c.style.display = model === "all" || c.dataset.model === model ? "" : "none";
    });
  }
  pills.forEach(p => p.addEventListener("click", () => {
    pills.forEach(x => x.classList.remove("active"));
    p.classList.add("active");
    apply();
  }));
  sortSel.addEventListener("change", apply);
  apply();
</script>

<style>
  .tool-page { max-width: var(--max-width); margin: 0 auto; padding: 48px 20px 0; }
  .tool-header { max-width: 760px; margin-bottom: 36px; }
  .kicker { font-family: var(--font-body); font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.1em; font-size: 0.65rem; color: var(--green); margin-bottom: 10px; }
  h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.8rem, 4vw, 2.6rem);
    letter-spacing: -0.01em; color: var(--text); margin-bottom: 14px; }
  .lede { color: var(--text-secondary); font-size: 1.05rem; line-height: 1.6; }
  .lede.small { font-size: 0.92rem; max-width: 640px; }

  .filter-bar { display: flex; flex-wrap: wrap; gap: 10px; align-items: center; margin-bottom: 28px; }
  .pill { border-radius: var(--radius-btn); border: 1px solid var(--border); background: var(--bg-card);
    color: var(--text); font-family: var(--font-body); font-size: 0.82rem; font-weight: 500;
    padding: 9px 18px; cursor: pointer; transition: all .15s ease; }
  .pill:hover { border-color: var(--green-accent); }
  .pill.active { background: var(--green-accent); border-color: var(--green-accent); color: var(--text-on-dark); }
  .pill:active { transform: scale(0.95); }
  .sort-wrap { margin-left: auto; display: flex; align-items: center; gap: 8px;
    font-size: 0.82rem; color: var(--text-secondary); }
  .sort-wrap select { border-radius: var(--radius-btn); border: 1px solid var(--border);
    background: var(--bg-card); color: var(--text); padding: 8px 14px; font-family: var(--font-body); }

  .clinic-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--gap); margin-bottom: 56px; }
  .clinic-card { background: var(--bg-card); border-radius: var(--radius); box-shadow: var(--shadow);
    padding: 24px; transition: box-shadow .2s ease; }
  .clinic-card:hover { box-shadow: var(--shadow-lg); }
  .clinic-top { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; }
  .clinic-card h2 { font-family: var(--font-display); font-size: 1.25rem; font-weight: 600; color: var(--text); }
  .badge { border-radius: var(--radius-btn); font-size: 0.6rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.05em; padding: 5px 11px; white-space: nowrap; }
  .badge-verified { background: var(--green-light); color: var(--green); }
  .badge-unverified { background: var(--gold-lightest); color: var(--gold); border: 1px solid var(--gold-light); }
  .model { font-size: 0.8rem; color: var(--text-muted); text-transform: uppercase;
    letter-spacing: 0.04em; margin: 8px 0 16px; }
  .fee-row { display: flex; gap: 28px; margin-bottom: 14px; }
  .fee { display: flex; flex-direction: column; }
  .fee-label { font-size: 0.6rem; font-weight: 600; letter-spacing: 0.08em; color: var(--text-muted); }
  .fee-value { font-family: var(--font-display); font-size: 1.5rem; font-weight: 600; color: var(--green); }
  .note { font-size: 0.88rem; color: var(--text-secondary); line-height: 1.5; margin-bottom: 8px; }
  .note.speed { color: var(--text); }
  .conditions { font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase;
    letter-spacing: 0.04em; margin: 12px 0 16px; }
  .clinic-link { display: inline-block; border-radius: var(--radius-btn); background: var(--green-accent);
    color: var(--text-on-dark); font-size: 0.85rem; font-weight: 600; padding: 10px 22px;
    text-decoration: none; transition: background .15s ease; }
  .clinic-link:hover { background: var(--green); }
  .clinic-link:active { transform: scale(0.95); }

  .tracker { margin-bottom: 48px; }
  .tracker h2 { font-family: var(--font-display); font-size: 1.5rem; font-weight: 600;
    border-bottom: 2px solid var(--green); padding-bottom: 10px; margin-bottom: 16px; color: var(--text); }
  .tracker svg { width: 100%; max-width: 640px; height: auto; background: var(--bg-card);
    border-radius: var(--radius); box-shadow: var(--shadow); margin: 12px 0; }
  .axis { stroke: var(--border); stroke-width: 1; }
  .trend { stroke: var(--green-accent); stroke-width: 2.5; fill: none; }
  .dot { fill: var(--green); }
  .val { font: 600 13px var(--font-body); fill: var(--green); }
  .lab { font: 500 11px var(--font-body); fill: rgba(0,0,0,0.38); }
  [data-theme="dark"] .lab { fill: rgba(163, 196, 184, 0.5); }

  .disclaimer-band { background: var(--green-bg); border-radius: var(--radius); padding: 20px 24px;
    margin-bottom: 48px; }
  .disclaimer-band p { font-size: 0.84rem; color: var(--text-secondary); line-height: 1.6; }
  .disclaimer-band p + p { margin-top: 8px; }

  @media (max-width: 900px) { .clinic-grid { grid-template-columns: 1fr; } }
  @media (max-width: 640px) { .sort-wrap { margin-left: 0; width: 100%; } }
</style>
