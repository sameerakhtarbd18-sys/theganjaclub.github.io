---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/Hero.astro";
import ArticleCard from "../components/ArticleCard.astro";
import Search from "../components/Search.astro";
import Newsletter from "../components/Newsletter.astro";
import AffiliateBanner from "../components/AffiliateBanner.astro";
import Icons from "../components/Icons.astro";

const allPosts = await getCollection("posts");
allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const editorial = allPosts.filter(p => !p.data.slug.includes("daily-briefing"));
const latestBriefing = allPosts.find(p => p.data.slug.includes("daily-briefing"));
const briefingHref = latestBriefing ? `/post/${latestBriefing.data.slug}` : "/uk";

const featured = editorial[0];
const latest = editorial.slice(1, 4);
const ukPosts = editorial.filter(p => p.data.region === "uk").slice(0, 3);
const worldPosts = editorial.filter(p => p.data.region !== "uk").slice(0, 3);

// Editor's picks: most recent editorial across all regions (different from featured)
const editorsPicks = editorial.slice(4, 7);

function getReadTime(body: string): number {
  return Math.max(1, Math.ceil((body || "").split(/\s+/).length / 200));
}

const today = new Date().toLocaleDateString("en-GB", {
  weekday: "long", day: "numeric", month: "long", year: "numeric"
});
---

<Base
  title="The Ganja Club — Medical Cannabis News, Policy & Culture"
  description="Daily intelligence on UK medical cannabis, global policy reform, industry analysis, and the culture that binds it all."
>

<Nav />
<Search />

<main id="main-content">

  <!-- Editorial masthead bar -->
  <div class="masthead-bar">
    <div class="masthead-inner">
      <span class="masthead-date">{today}</span>
      <span class="masthead-sep" aria-hidden="true"></span>
      <span class="masthead-edition">Daily Edition</span>
      <span class="masthead-spacer"></span>
      <a href="/eligibility" class="masthead-cta">Check your eligibility <Icons name="arrow-right" /></a>
    </div>
  </div>

  <!-- Identity hero: orient first -->
  <section class="identity-hero">
    <p class="identity-kicker">INDEPENDENT &middot; UK &middot; PATIENT-FIRST</p>
    <h1>Medical cannabis in the UK,<br />covered properly.</h1>
    <p class="identity-sub">
      Daily briefings, patient tools and guides for the system nobody explains.
    </p>
    <div class="identity-ctas">
      <a class="cta cta-filled" href={briefingHref}>Today's briefing</a>
      <a class="cta cta-outline" href="/clinics">Compare clinics</a>
      <a class="cta cta-ghost" href="/guides">Start here: guides</a>
    </div>
  </section>

  <!-- Patient tools band -->
  <section class="tools-band">
    <div class="tools-inner">
      <div class="section-label">
        <span class="section-rule"></span>
        <span class="section-label-text">PATIENT TOOLS</span>
        <span class="section-rule"></span>
      </div>
      <div class="tools-grid">
        <a class="tool-card" href="/eligibility">
          <span class="tool-icon"><Icons name="clipboard" /></span>
          <span class="tool-name">Eligibility checker</span>
          <span class="tool-desc">Could you qualify? How the UK system actually works, in two minutes.</span>
          <span class="tool-go">Open tool <Icons name="arrow-right" /></span>
        </a>
        <a class="tool-card" href="/clinics">
          <span class="tool-icon"><Icons name="building" /></span>
          <span class="tool-name">Compare clinics</span>
          <span class="tool-desc">Every major UK clinic — fees, models and onboarding speed, side by side.</span>
          <span class="tool-go">Open tool <Icons name="arrow-right" /></span>
        </a>
        <a class="tool-card" href="/strains">
          <span class="tool-icon"><Icons name="leaf" /></span>
          <span class="tool-name">Strain explorer</span>
          <span class="tool-desc">Cannabinoid ranges, terpenes and UK availability — built for patients.</span>
          <span class="tool-go">Open tool <Icons name="arrow-right" /></span>
        </a>
      </div>
    </div>
  </section>

  {featured && <Hero post={featured} />}

  <section class="section">
    <div class="section-header">
      <div class="section-header-left">
        <span class="section-kicker">LATEST</span>
        <h2>Latest Briefings</h2>
      </div>
      <a href="/uk" class="section-link">View All <Icons name="arrow-right" /></a>
    </div>
    <div class="card-grid">
      {latest.map(post => <ArticleCard {...post.data} readTime={getReadTime(post.body || "")} />)}
    </div>
  </section>

  <AffiliateBanner />

  <section class="section">
    <div class="section-header">
      <div class="section-header-left">
        <span class="section-kicker">UNITED KINGDOM</span>
        <h2>UK News</h2>
      </div>
      <a href="/uk" class="section-link">All UK <Icons name="arrow-right" /></a>
    </div>
    <div class="card-grid">
      {ukPosts.map(post => <ArticleCard {...post.data} readTime={getReadTime(post.body || "")} />)}
    </div>
  </section>

  {editorsPicks.length > 0 && (
    <section class="section section-alt">
      <div class="section-header">
        <div class="section-header-left">
          <span class="section-kicker">WORLD</span>
          <h2>Europe, USA &amp; Global</h2>
        </div>
        <a href="/global" class="section-link">All World <Icons name="arrow-right" /></a>
      </div>
      <div class="card-grid">
        {worldPosts.map(post => <ArticleCard {...post.data} readTime={getReadTime(post.body || "")} />)}
      </div>
    </section>
  )}

  <!-- Eligibility CTA band -->
  <section class="eligibility-cta-band">
    <div class="eligibility-cta-inner">
      <div class="eligibility-cta-content">
        <span class="eligibility-cta-kicker">PATIENT ACCESS</span>
        <h2>Could you qualify for medical cannabis?</h2>
        <p>Medical cannabis has been legal in the UK since 2018. Most patients don't know it's an option. Take the two-minute checker to find out how the system works and whether you match the profile clinics assess.</p>
        <a href="/eligibility" class="eligibility-cta-btn">Check your eligibility <Icons name="arrow-right" /></a>
      </div>
    </div>
  </section>

  <Newsletter />
</main>

<Footer />

<button class="back-to-top" id="back-to-top" aria-label="Back to top"><Icons name="arrow-up" /></button>
<script>
  const btn = document.getElementById("back-to-top")!;
  window.addEventListener("scroll", () => btn.classList.toggle("visible", window.scrollY > 500));
  btn.addEventListener("click", () => window.scrollTo({ top: 0, behavior: "smooth" }));
</script>

</Base>

<style>
  /* ── Masthead bar ── */
  .masthead-bar {
    background: var(--green-house);
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .masthead-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 8px 20px;
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.76rem;
    color: var(--text-on-dark-soft);
  }
  .masthead-date { font-weight: 500; letter-spacing: 0.01em; }
  .masthead-sep { width: 1px; height: 12px; background: rgba(255,255,255,0.2); }
  .masthead-edition {
    font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em;
    font-size: 0.66rem; color: var(--gold);
  }
  .masthead-spacer { flex: 1; }
  .masthead-cta {
    color: var(--gold-light) !important;
    font-weight: 600;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.76rem;
    transition: color 0.15s ease;
  }
  .masthead-cta:hover { color: #fff !important; }

  /* ── Identity hero ── */
  .identity-hero {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 72px 20px 56px;
    text-align: center;
  }
  .identity-kicker {
    font-weight: 600; font-size: 0.65rem; letter-spacing: 0.24em;
    color: var(--gold); margin-bottom: 16px;
  }
  .identity-hero h1 {
    font-family: var(--font-display); font-weight: 600;
    font-size: clamp(2rem, 5vw, 3.2rem); letter-spacing: -0.01em;
    line-height: 1.15; color: var(--text); margin-bottom: 16px;
  }
  .identity-sub {
    color: var(--text-secondary); font-size: 1.1rem; line-height: 1.6;
    max-width: 520px; margin: 0 auto 28px;
  }
  .identity-ctas { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .cta {
    border-radius: var(--radius-btn); font-size: 0.92rem; font-weight: 600;
    padding: 13px 28px; text-decoration: none; transition: all .15s ease;
  }
  .cta:active { transform: scale(0.95); }
  .cta-filled { background: var(--green-accent); color: var(--text-on-dark); }
  .cta-filled:hover { background: var(--green); }
  .cta-outline { border: 1.5px solid var(--green-accent); color: var(--green-accent); }
  .cta-outline:hover { background: var(--green-bg); }
  .cta-ghost { border: 1px solid var(--border); color: var(--text-secondary); }
  .cta-ghost:hover { border-color: var(--green-accent); color: var(--green-accent); }

  /* ── Section label (editorial rule) ── */
  .section-label {
    display: flex; align-items: center; gap: 14px;
    margin-bottom: 24px;
  }
  .section-rule {
    flex: 1; height: 1px; background: rgba(255,255,255,0.16);
  }
  .section-label-text {
    font-family: var(--font-body);
    font-weight: 700; font-size: 0.68rem;
    letter-spacing: 0.18em; color: var(--gold);
  }

  /* ── Tools band ── */
  .tools-band { background: var(--green-house); margin-bottom: 8px; }
  .tools-inner { max-width: var(--max-width); margin: 0 auto; padding: 40px 20px 44px; }
  .tools-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--gap); }
  .tool-card {
    display: flex; flex-direction: column; gap: 8px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.14);
    border-radius: var(--radius); padding: 22px;
    text-decoration: none; transition: background .15s ease, border-color .15s ease, transform .15s ease;
  }
  .tool-card:hover {
    background: rgba(255,255,255,0.1); border-color: var(--gold-light);
    transform: translateY(-2px);
  }
  .tool-icon {
    width: 40px; height: 40px; border-radius: var(--radius);
    background: rgba(203,162,88,0.12); display: flex; align-items: center;
    justify-content: center; color: var(--gold); margin-bottom: 4px;
  }
  .tool-name { font-family: var(--font-display); font-weight: 600; font-size: 1.15rem; color: var(--text-on-dark); }
  .tool-desc { font-size: 0.88rem; line-height: 1.5; color: var(--text-on-dark-soft); }
  .tool-go { font-size: 0.78rem; font-weight: 600; color: var(--gold); margin-top: 6px; display: flex; align-items: center; gap: 4px; }

  /* ── Section headers (editorial) ── */
  .section { max-width: var(--max-width); margin: 0 auto; padding: 48px 20px; }
  .section-alt { background: var(--green-bg); }
  .section-header {
    display: flex; justify-content: space-between; align-items: flex-end;
    margin-bottom: 28px; padding-bottom: 16px;
    border-bottom: 2px solid var(--border);
  }
  .section-header-left { display: flex; flex-direction: column; gap: 4px; }
  .section-kicker {
    font-family: var(--font-body);
    font-weight: 700; font-size: 0.62rem;
    letter-spacing: 0.16em; color: var(--green);
    text-transform: uppercase;
  }
  .section-header h2 {
    font-family: var(--font-display); font-weight: 600;
    font-size: 1.8rem; letter-spacing: -0.01em; color: var(--text);
  }
  .section-link {
    font-size: 0.86rem; font-weight: 600; color: var(--green-accent);
    text-decoration: none; display: flex; align-items: center; gap: 4px;
    transition: color 0.15s ease;
  }
  .section-link:hover { color: var(--green); }

  /* ── Eligibility CTA band ── */
  .eligibility-cta-band {
    background: var(--green-house);
    margin-top: 0;
  }
  .eligibility-cta-inner {
    max-width: var(--max-width); margin: 0 auto; padding: 56px 20px;
  }
  .eligibility-cta-content { max-width: 640px; }
  .eligibility-cta-kicker {
    font-weight: 700; font-size: 0.65rem; letter-spacing: 0.18em;
    color: var(--gold); text-transform: uppercase;
    display: block; margin-bottom: 12px;
  }
  .eligibility-cta-content h2 {
    font-family: var(--font-display); font-weight: 600;
    font-size: clamp(1.6rem, 3.5vw, 2.2rem); color: var(--text-on-dark);
    margin-bottom: 16px; letter-spacing: -0.01em; line-height: 1.2;
  }
  .eligibility-cta-content p {
    font-size: 1rem; line-height: 1.65; color: var(--text-on-dark-soft);
    margin-bottom: 24px;
  }
  .eligibility-cta-btn {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--green-accent); color: var(--text-on-dark);
    font-weight: 600; font-size: 0.95rem; padding: 14px 32px;
    border-radius: var(--radius-btn); text-decoration: none;
    transition: background 0.15s ease, transform 0.15s ease;
  }
  .eligibility-cta-btn:hover { background: var(--green); }
  .eligibility-cta-btn:active { transform: scale(0.95); }

  @media (max-width: 900px) {
    .tools-grid { grid-template-columns: 1fr; }
    .masthead-cta { display: none; }
  }
  @media (max-width: 640px) {
    .identity-hero { padding: 52px 20px 40px; }
    .identity-ctas .cta { width: 100%; text-align: center; }
    .section-header { flex-direction: column; align-items: flex-start; gap: 12px; }
    .section-header h2 { font-size: 1.5rem; }
  }
</style>
