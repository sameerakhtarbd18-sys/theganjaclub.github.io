---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/Hero.astro";
import ArticleCard from "../components/ArticleCard.astro";
import Search from "../components/Search.astro";
import Newsletter from "../components/Newsletter.astro";
import AffiliateBanner from "../components/AffiliateBanner.astro";
import Icons from "../components/Icons.astro";
import PlateLeaf from "../components/PlateLeaf.astro";

const allPosts = await getCollection("posts");
allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const editorial = allPosts.filter(p => !p.data.slug.includes("daily-briefing"));
const latestBriefing = allPosts.find(p => p.data.slug.includes("daily-briefing"));
const briefingHref = latestBriefing ? `/post/${latestBriefing.data.slug}` : "/uk";

const featured = editorial[0];
const latest = editorial.slice(1, 4);
const ukPosts = editorial.filter(p => p.data.region === "uk").slice(0, 3);
const worldPosts = editorial.filter(p => p.data.region !== "uk").slice(0, 3);

// Editor's picks: most recent editorial across all regions (different from featured)
const editorsPicks = editorial.slice(4, 7);

function getReadTime(body: string): number {
  return Math.max(1, Math.ceil((body || "").split(/\s+/).length / 200));
}

const today = new Date().toLocaleDateString("en-GB", {
  weekday: "long", day: "numeric", month: "long", year: "numeric"
});
---

<Base
  title="The Ganja Club — Medical Cannabis News, Policy & Culture"
  description="Daily intelligence on UK medical cannabis, global policy reform, industry analysis, and the culture that binds it all."
>

<Nav />
<Search />

<main id="main-content">

  <!-- Journal dateline -->
  <div class="masthead-bar">
    <div class="masthead-inner">
      <span class="masthead-date">{today}</span>
      <span class="masthead-sep" aria-hidden="true"></span>
      <span class="masthead-edition">Daily Edition</span>
      <span class="masthead-spacer"></span>
      <a href="/eligibility" class="masthead-cta">Check your eligibility <Icons name="arrow-right" /></a>
    </div>
  </div>

  <!-- Journal title page — the monograph frontispiece -->
  <section class="journal-title-page">
    <PlateLeaf class="botanical-watermark" />
    <span class="plate-number" aria-hidden="true">Pl.&nbsp;I&nbsp;—&nbsp;Cannabis&nbsp;sativa&nbsp;L.</span>
    <p class="title-kicker">Independent &middot; UK &middot; Patient-first</p>
    <h1>Medical cannabis in the UK,<br />covered properly.</h1>
    <p class="title-sub">
      Daily briefings, patient tools and guides for the system nobody explains.
    </p>
    <div class="identity-ctas">
      <a class="cta cta-filled" href={briefingHref}>Today's briefing</a>
      <a class="cta cta-outline" href="/clinics">Compare clinics</a>
      <a class="cta cta-ghost" href="/guides">Start here: guides</a>
    </div>
  </section>

  <!-- Instruments — the patient tools band -->
  <section class="tools-band">
    <div class="tools-inner">
      <div class="section-label">
        <span class="section-rule"></span>
        <span class="section-label-text">Instruments &middot; Patient Tools</span>
        <span class="section-rule"></span>
      </div>
      <div class="tools-grid">
        <a class="tool-card" href="/eligibility">
          <span class="tool-icon"><Icons name="clipboard" /></span>
          <span class="tool-name">Eligibility checker</span>
          <span class="tool-desc">Could you qualify? How the UK system actually works, in two minutes.</span>
          <span class="tool-go">Open tool <Icons name="arrow-right" /></span>
        </a>
        <a class="tool-card" href="/clinics">
          <span class="tool-icon"><Icons name="building" /></span>
          <span class="tool-name">Compare clinics</span>
          <span class="tool-desc">Every major UK clinic — fees, models and onboarding speed, side by side.</span>
          <span class="tool-go">Open tool <Icons name="arrow-right" /></span>
        </a>
        <a class="tool-card" href="/strains">
          <span class="tool-icon"><Icons name="leaf" /></span>
          <span class="tool-name">Strain explorer</span>
          <span class="tool-desc">Cannabinoid ranges, terpenes and UK availability — built for patients.</span>
          <span class="tool-go">Open tool <Icons name="arrow-right" /></span>
        </a>
      </div>
    </div>
  </section>

  {featured && <Hero post={featured} />}

  <div class="fleuron-rule" role="presentation">
    <Icons name="fleuron" class="section-fleuron" />
  </div>

  <section class="section">
    <header class="plate-header">
      <div class="plate-header-left">
        <span class="plate-number" aria-hidden="true">Pl.&nbsp;III</span>
        <h2>Latest Briefings</h2>
      </div>
      <a href="/uk" class="plate-link">View All <Icons name="arrow-right" /></a>
    </header>
    <div class="card-grid">
      {latest.map(post => <ArticleCard {...post.data} readTime={getReadTime(post.body || "")} />)}
    </div>
  </section>

  <AffiliateBanner />

  <section class="section">
    <header class="plate-header">
      <div class="plate-header-left">
        <span class="plate-number" aria-hidden="true">Pl.&nbsp;IV</span>
        <h2>UK News</h2>
      </div>
      <a href="/uk" class="plate-link">All UK <Icons name="arrow-right" /></a>
    </header>
    <div class="card-grid">
      {ukPosts.map(post => <ArticleCard {...post.data} readTime={getReadTime(post.body || "")} />)}
    </div>
  </section>

  <div class="fleuron-rule" role="presentation">
    <Icons name="fleuron" class="section-fleuron" />
  </div>

  {editorsPicks.length > 0 && (
    <section class="section">
      <header class="plate-header">
        <div class="plate-header-left">
          <span class="plate-number" aria-hidden="true">Pl.&nbsp;V</span>
          <h2>Europe, USA &amp; Global</h2>
        </div>
        <a href="/global" class="plate-link">All World <Icons name="arrow-right" /></a>
      </header>
      <div class="card-grid">
        {worldPosts.map(post => <ArticleCard {...post.data} readTime={getReadTime(post.body || "")} />)}
      </div>
    </section>
  )}

  <!-- Eligibility band -->
  <section class="feature-band">
    <div class="feature-band-inner">
      <div class="eligibility-cta-content">
        <span class="band-kicker">Patient Access</span>
        <h2>Could you qualify for medical cannabis?</h2>
        <p>Medical cannabis has been legal in the UK since 2018. Most patients don't know it's an option. Take the two-minute checker to find out how the system works and whether you match the profile clinics assess.</p>
        <a href="/eligibility" class="cta cta-gilt band-cta">Check your eligibility <Icons name="arrow-right" /></a>
      </div>
    </div>
  </section>

  <Newsletter />
</main>

<Footer />

<button class="back-to-top" id="back-to-top" aria-label="Back to top"><Icons name="arrow-up" /></button>
<script>
  const btn = document.getElementById("back-to-top")!;
  window.addEventListener("scroll", () => btn.classList.toggle("visible", window.scrollY > 500));
  btn.addEventListener("click", () => window.scrollTo({ top: 0, behavior: "smooth" }));
</script>

</Base>

<style>
  /* ── Journal dateline ── */
  .masthead-bar {
    background: var(--bg-band);
    border-bottom: 1px solid rgba(216,188,126,0.25);
  }
  .masthead-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 8px 20px;
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.76rem;
    color: var(--text-on-dark-soft);
  }
  .masthead-date {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 480;
    letter-spacing: 0.01em;
  }
  .masthead-sep { width: 1px; height: 12px; background: rgba(233,239,233,0.2); }
  .masthead-edition {
    font-family: var(--font-ui);
    font-weight: 600; text-transform: uppercase; letter-spacing: 0.14em;
    font-size: 0.64rem; color: var(--gilt-400);
  }
  .masthead-spacer { flex: 1; }
  .masthead-cta {
    color: var(--gilt-400) !important;
    font-weight: 600;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.76rem;
    transition: color var(--dur-1) var(--ease-out);
  }
  .masthead-cta:hover { color: var(--text-on-dark) !important; }

  .identity-ctas { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }

  /* ── Instruments band ── */
  .tools-band { background: var(--bg-band); }
  .tools-inner { max-width: var(--max-width); margin: 0 auto; padding: 44px 20px 48px; }
  .section-label {
    display: flex; align-items: center; gap: 14px;
    margin-bottom: 28px;
  }
  .section-rule { flex: 1; height: 1px; background: rgba(233,239,233,0.14); }
  .section-label-text {
    font-family: var(--font-ui);
    font-weight: 600; font-size: 0.66rem; text-transform: uppercase;
    letter-spacing: 0.18em; color: var(--gilt-400);
  }
  .tools-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--gap); }
  .tool-card {
    display: flex; flex-direction: column; gap: 8px;
    background: rgba(233,239,233,0.05);
    border: 1px solid rgba(233,239,233,0.14);
    border-radius: var(--r-3); padding: 22px;
    text-decoration: none;
    transition: background var(--dur-1) var(--ease-out), border-color var(--dur-1) var(--ease-out);
  }
  .tool-card:hover {
    background: rgba(233,239,233,0.08);
    border-color: var(--gilt-400);
  }
  .tool-icon {
    width: 40px; height: 40px; border-radius: var(--r-2);
    background: rgba(216,188,126,0.12);
    display: flex; align-items: center; justify-content: center;
    color: var(--gilt-400); margin-bottom: 4px;
  }
  .tool-icon :global(svg) { color: var(--gilt-400); }
  .tool-name {
    font-family: var(--font-display); font-weight: 560;
    font-size: 1.15rem; color: var(--text-on-dark);
  }
  .tool-desc { font-size: 0.88rem; line-height: 1.5; color: var(--text-on-dark-soft); }
  .tool-go {
    font-family: var(--font-ui);
    font-size: 0.74rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--gilt-400); margin-top: 6px;
    display: flex; align-items: center; gap: 4px;
  }

  /* ── Eligibility band content ── */
  .eligibility-cta-content { max-width: 640px; }
  .eligibility-cta-content h2 {
    font-size: clamp(1.6rem, 3.5vw, 2.2rem);
    margin-bottom: 16px; line-height: 1.2;
  }
  .eligibility-cta-content p {
    font-size: 1rem; line-height: 1.65;
    margin-bottom: 24px;
  }
  .band-cta { font-size: 0.9rem; }

  @media (max-width: 900px) {
    .tools-grid { grid-template-columns: 1fr; }
    .masthead-cta { display: none; }
  }
  @media (max-width: 640px) {
    .identity-ctas { flex-direction: column; }
    .identity-ctas .cta { width: 100%; text-align: center; }
  }
</style>
