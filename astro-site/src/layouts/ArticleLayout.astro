---
import Base from "./Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import ArticleCard from "../components/ArticleCard.astro";
import AffiliateBanner from "../components/AffiliateBanner.astro";
import BreadcrumbBar from "../components/BreadcrumbBar.astro";
import Icons from "../components/Icons.astro";
import { marked } from "marked";

export interface RelatedPost {
  title: string;
  slug: string;
  excerpt: string;
  image: string;
  tags: string[];
  date: string;
}

export interface Props {
  title: string;
  slug: string;
  date: string;
  region: string;
  excerpt: string;
  image: string;
  tags: string[];
  body: string;
  author?: string;
  sources?: string[];
  plateNumber?: string;
  related?: RelatedPost[];
}

const {
  title,
  slug,
  date,
  region,
  excerpt,
  image,
  tags = [],
  body = "",
  author = "The Ganja Club",
  sources = [],
  plateNumber,
  related = [],
} = Astro.props;

/* Convert markdown body to HTML — handles both pure markdown and inline HTML */
const htmlBody = marked.parse(body, { breaks: true });

const siteUrl = "https://theganjaclub.co.uk";
const postUrl = `${siteUrl}/post/${slug}`;

/* Absolute image URL for structured data / OG tags */
const fullImage = image
  ? (image.startsWith("http") ? image : `${siteUrl}${image}`)
  : `${siteUrl}/images/flower/pexels-kindelmedia-7667912.webp`;

/* Display image src — works in dev and prod */
const heroSrc = image.startsWith("http") ? image : image;

/* Reading time — strip HTML, count words, ~225 wpm */
const wordCount = (htmlBody || "")
  .replace(/<[^>]*>/g, " ")
  .split(/\s+/)
  .filter(Boolean)
  .length;
const readingTime = Math.max(1, Math.ceil(wordCount / 225));

/* Plate number — from prop, else derived deterministically from the slug */
function toRoman(n: number): string {
  const table: [number, string][] = [
    [40, "XL"], [10, "X"], [9, "IX"], [5, "V"], [4, "IV"], [1, "I"],
  ];
  let out = "";
  for (const [v, sym] of table) {
    while (n >= v) { out += sym; n -= v; }
  }
  return out;
}
function slugHash(s: string): number {
  let h = 0;
  for (let i = 0; i < s.length; i++) h = (h * 31 + s.charCodeAt(i)) >>> 0;
  return h;
}
const plateLabel = plateNumber || `Pl. ${toRoman((slugHash(slug) % 48) + 1)}`;

/* Region display */
const regionMap: Record<string, string> = {
  uk: "UK",
  europe: "Europe",
  usa: "USA",
  global: "Global",
  Research: "Research",
};
const regionLabel = regionMap[region] || "News";
const backRegionLabel = region === "global" ? "World" : regionLabel;
const regionUrl = region === "Research" ? "/research" : `/${region}`;

/* Tag → URL mapping: region tags route to region pages, topic tags to /guides */
const regionTagMap: Record<string, string> = {
  uk: "/uk",
  europe: "/europe",
  usa: "/usa",
  global: "/global",
  research: "/research",
};
function tagUrl(tag: string): string {
  const lower = tag.toLowerCase();
  if (lower in regionTagMap) return regionTagMap[lower];
  return `/guides?tag=${encodeURIComponent(tag)}`;
}

/* Author display name */
const authorDisplay = author || "The Ganja Club";
const authorInitials = authorDisplay === "The Ganja Club" ? "TGC" : authorDisplay.split(" ").map((w: string) => w[0]).join("").slice(0, 3).toUpperCase();

/* Formatted date */
const dateObj = new Date(date);
const formattedDate = dateObj.toLocaleDateString("en-GB", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
const kickerText = `${regionLabel} · ${formattedDate.toUpperCase()}`;

/* JSON-LD: Article schema */
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description: excerpt,
  image: [fullImage],
  datePublished: date,
  dateModified: date,
  author: { "@type": "Organization", name: "The Ganja Club", url: siteUrl },
  publisher: {
    "@type": "Organization",
    name: "The Ganja Club",
    url: siteUrl,
    logo: { "@type": "ImageObject", url: `${siteUrl}/logo-mark.svg` },
  },
  mainEntityOfPage: { "@type": "WebPage", "@id": postUrl },
};

/* JSON-LD: Breadcrumb */
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
    { "@type": "ListItem", position: 2, name: regionLabel, item: `${siteUrl}${regionUrl}` },
    { "@type": "ListItem", position: 3, name: title, item: postUrl },
  ],
};
---

<Base
  title={`${title} — The Ganja Club`}
  description={excerpt}
  ogImage={image}
  ogType="article"
  canonicalUrl={postUrl}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} is:inline />

  <div class="reading-progress" aria-hidden="true"><div class="reading-progress-bar"></div></div>

  <AffiliateBanner />
  <Nav />
  <BreadcrumbBar region={region} title={title} />

  <main id="main-content">
    <article class="article-page">
      <a href={regionUrl} class="article-back-link">
        <Icons name="arrow-left" />
        Back to {backRegionLabel} News
      </a>

      <!-- Hero — the article's plate -->
      <header class="article-hero-section">
        <figure class="article-hero-figure">
          <div class="article-hero-img-wrap">
            <img
              src={heroSrc}
              alt={title}
              class="article-hero-img"
              width="1200"
              height="675"
              loading="eager"
              decoding="async" />
          </div>
          <figcaption class="article-hero-plate" aria-hidden="true">
            <span class="plate-number">{plateLabel}</span>
          </figcaption>
        </figure>

        <div class="article-hero-text">
          <div class="article-kicker-line">{kickerText}</div>
          <h1 class="article-headline">{title}</h1>
          <p class="article-standfirst">{excerpt}</p>
          <div class="article-author-byline">
            <span class="author-rule" aria-hidden="true"></span>
            <span class="author-text">By {authorDisplay}</span>
          </div>
          <div class="article-byline">
            <time datetime={dateObj.toISOString()}>{formattedDate}</time>
            <span class="byline-dot" aria-hidden="true">·</span>
            <span>{readingTime} min read</span>
          </div>
        </div>
      </header>

      <!-- Body: serration rail + prose + share rail -->
      <div class="article-body-grid">
        <div class="serration-rail" id="serration-rail" aria-hidden="true">
          <span class="rail-cap">{plateLabel.replace("Pl. ", "")}</span>
        </div>

        <div class="article-prose article-body" set:html={htmlBody} />

        <aside class="article-share-rail" aria-label="Share this article">
          <span class="share-rail-label">Share</span>
          <a
            href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(postUrl)}`}
            target="_blank"
            rel="noopener"
            class="share-rail-btn"
            aria-label="Share on X">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <button class="share-rail-btn" data-share="copy" aria-label="Copy link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
              <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
            </svg>
          </button>
        </aside>
      </div>

      <!-- End mark -->
      <div class="article-endmark" aria-hidden="true">
        <Icons name="fleuron" class="endmark-fleuron" />
      </div>

      <!-- References — journal-style sources block -->
      {sources.length > 0 && (
        <section class="article-sources">
          <h2>References</h2>
          <ol>
            {sources.map((src: string) => <li set:html={marked.parseInline(src)} />)}
          </ol>
        </section>
      )}

      <!-- Tags -->
      {tags.length > 0 && (
        <div class="article-tags-bar">
          {tags.map((tag: string) => (
            <a href={tagUrl(tag)} class="tag-pill">{tag}</a>
          ))}
        </div>
      )}

      <!-- Newsletter CTA -->
      <section class="article-newsletter-cta">
        <div class="article-newsletter-inner">
          <span class="article-newsletter-kicker">Stay Informed</span>
          <h3>Get the daily briefing in your inbox</h3>
          <p>UK medical cannabis news, policy changes and patient resources — delivered daily, free.</p>
          <a href="/#newsletter" class="article-newsletter-btn">Subscribe <Icons name="arrow-right" /></a>
        </div>
      </section>

      <!-- Related articles -->
      {related.length > 0 && (
        <section class="article-related">
          <div class="article-related-header">
            <span class="article-related-kicker">More to Read</span>
            <h2 class="article-related-heading">Read Next</h2>
          </div>
          <div class="article-related-grid">
            {related.map((p: RelatedPost) => (
              <ArticleCard
                title={p.title}
                slug={p.slug}
                excerpt={p.excerpt}
                image={p.image}
                tags={p.tags}
                date={p.date}
              />
            ))}
          </div>
        </section>
      )}
    </article>
  </main>

  <Footer />

  <script>
    const copyBtn = document.querySelector<HTMLButtonElement>('[data-share="copy"]');
    if (copyBtn) {
      const originalSvg = copyBtn.querySelector('svg')?.innerHTML || '';
      copyBtn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(window.location.href);
          copyBtn.classList.add('copied');
          const svg = copyBtn.querySelector('svg');
          if (svg) {
            svg.innerHTML = '<path d="M20 6L9 17l-5-5" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>';
          }
          setTimeout(() => {
            copyBtn.classList.remove('copied');
            if (svg) svg.innerHTML = originalSvg;
          }, 2000);
        } catch {
          /* Clipboard API unavailable — silently fail */
        }
      });
    }
  </script>

  <script>
    // Reading progress — drives the top bar and the serration rail fill
    const progressBar = document.querySelector<HTMLElement>('.reading-progress-bar');
    const serrationRail = document.getElementById('serration-rail');
    if (progressBar || serrationRail) {
      let ticking = false;
      function updateProgress() {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = docHeight > 0 ? Math.min(scrollTop / docHeight, 1) : 0;
        if (progressBar) progressBar.style.transform = `scaleX(${progress})`;
        if (serrationRail) serrationRail.style.setProperty('--scroll-pct', String(progress * 100));
        ticking = false;
      }
      window.addEventListener('scroll', () => {
        if (!ticking) {
          window.requestAnimationFrame(updateProgress);
          ticking = true;
        }
      }, { passive: true });
      updateProgress();
    }
  </script>
</Base>

<style>
  /* ═══════════════════════════════════════════════
     Article Page — The Botanical Journal
     Fraunces · Source Serif 4 · Inter · plate motifs
     ═══════════════════════════════════════════════ */

  .article-page {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 24px 24px 64px;
  }

  /* ── Hero — framed as a botanical plate ── */
  .article-hero-section { margin-bottom: 48px; }

  .article-hero-figure {
    max-width: 960px;
    margin: 0 auto 28px;
  }
  .article-hero-img-wrap {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border: 1px solid var(--plate-stroke);
    border-radius: var(--r-1);
    padding: 6px;
    background: var(--bg-card);
    position: relative;
  }
  .article-hero-img-wrap::after {
    content: '';
    position: absolute; inset: 3px;
    border: 1px solid var(--plate-stroke);
    opacity: 0.35; pointer-events: none;
    border-radius: 1px;
  }
  .article-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 1px;
  }
  .article-hero-plate {
    display: flex;
    justify-content: flex-end;
    padding-top: 8px;
  }
  .article-hero-plate .plate-number { font-size: 0.8rem; }

  .article-hero-text {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 8px;
  }
  .article-kicker-line {
    font-family: var(--font-ui);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--label-tracking);
    color: var(--accent-text);
    margin-bottom: 12px;
  }
  .article-headline {
    font-family: var(--font-display);
    font-size: var(--step-4);
    line-height: 1.12;
    color: var(--text);
    font-weight: 560;
    letter-spacing: -0.015em;
    margin-bottom: 16px;
  }
  .article-standfirst {
    font-family: var(--font-text);
    font-style: italic;
    font-size: var(--step-0);
    line-height: 1.65;
    color: var(--text-2);
    letter-spacing: -0.005em;
    margin-bottom: 20px;
  }
  .article-byline {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-ui);
    font-size: 0.8rem;
    color: var(--text-3);
    font-weight: 500;
    letter-spacing: 0.02em;
    font-variant-numeric: tabular-nums;
  }
  .byline-dot { opacity: 0.5; }

  /* ── Reading progress (top bar) ── */
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    z-index: 9999;
    pointer-events: none;
    background: transparent;
  }
  .reading-progress-bar {
    width: 100%;
    height: 100%;
    transform: scaleX(0);
    transform-origin: left center;
    background: var(--accent);
    transition: transform 0.15s var(--ease-out);
  }

  /* ── Author byline ── */
  .article-author-byline {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
  }
  .author-rule {
    display: inline-block;
    width: 24px;
    height: 1px;
    background: var(--accent);
    flex-shrink: 0;
  }
  .author-text {
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    color: var(--text-2);
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  /* ── Body grid: serration rail + prose + share rail ── */
  .article-body-grid {
    display: flex;
    gap: 36px;
    justify-content: center;
    max-width: 880px;
    margin: 0 auto;
  }

  /* ── Share rail (sticky, desktop) — journal register ── */
  .article-share-rail {
    position: sticky;
    top: calc(var(--banner-height) + var(--nav-height) + 44px);
    align-self: flex-start;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }
  .share-rail-label {
    font-family: var(--font-ui);
    font-size: 0.6rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--label-tracking);
    color: var(--text-3);
    writing-mode: vertical-rl;
    text-orientation: mixed;
    margin-bottom: 6px;
  }
  .share-rail-btn {
    width: 38px;
    height: 38px;
    border-radius: var(--r-2);
    border: 1px solid var(--hairline);
    background: var(--bg-card);
    color: var(--text-2);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    text-decoration: none;
    transition: border-color var(--dur-1) var(--ease-out), color var(--dur-1) var(--ease-out);
  }
  .share-rail-btn:hover {
    border-color: var(--link);
    color: var(--link);
  }
  .share-rail-btn:active { transform: scale(var(--btn-active-scale)); }
  .share-rail-btn.copied {
    background: var(--leaf-600);
    color: #fff;
    border-color: var(--leaf-600);
  }

  /* ── Prose — the reading experience (base styles from global .article-body) ── */
  .article-prose {
    max-width: 66ch;
    width: 100%;
  }
  .article-prose :global(img) {
    width: 100%;
    height: auto;
    border: 1px solid var(--hairline);
    border-radius: var(--r-1);
    margin: 1.5rem 0;
  }
  .article-prose :global(code) {
    background: var(--bg-well);
    color: var(--text);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.88em;
  }
  .article-prose :global(pre) {
    background: var(--bg-well);
    border: 1px solid var(--hairline);
    border-radius: var(--r-2);
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.25rem;
  }
  .article-prose :global(pre code) { background: none; padding: 0; }

  /* ── End mark ── */
  .article-endmark {
    max-width: 66ch;
    margin: var(--sp-5) auto 0;
    display: flex;
    justify-content: center;
  }
  .article-endmark :global(.endmark-fleuron) {
    width: 26px; height: 20px;
    color: var(--accent-text);
  }

  /* ── Tags ── */
  .article-tags-bar {
    max-width: 720px;
    margin: 48px auto 0;
    padding-top: 32px;
    border-top: 1px solid var(--hairline);
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .tag-pill {
    display: inline-block;
    padding: 6px 14px;
    border: 1px solid var(--hairline);
    border-radius: var(--r-2);
    font-family: var(--font-ui);
    font-size: 0.76rem;
    font-weight: 500;
    color: var(--text-2);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: border-color var(--dur-1) var(--ease-out), color var(--dur-1) var(--ease-out);
  }
  .tag-pill:hover {
    border-color: var(--link);
    color: var(--link);
  }
  .tag-pill:active { transform: scale(var(--btn-active-scale)); }

  /* ── Newsletter CTA ── */
  .article-newsletter-cta {
    max-width: 720px;
    margin: 48px auto 0;
  }
  .article-newsletter-inner {
    background: var(--bg-band);
    border-radius: var(--r-3);
    padding: 36px 32px;
    text-align: center;
  }
  .article-newsletter-kicker {
    font-family: var(--font-ui);
    font-weight: 600; font-size: 0.64rem; letter-spacing: 0.16em;
    color: var(--gilt-400); text-transform: uppercase;
    display: block; margin-bottom: 10px;
  }
  .article-newsletter-inner h3 {
    font-family: var(--font-display); font-size: 1.4rem; font-weight: 560;
    color: var(--text-on-dark); margin-bottom: 10px; letter-spacing: -0.01em;
  }
  .article-newsletter-inner p {
    font-size: 0.92rem; line-height: 1.55; color: var(--text-on-dark-soft);
    margin-bottom: 20px; max-width: 420px; margin-left: auto; margin-right: auto;
  }
  .article-newsletter-btn {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--gilt-400); color: var(--leaf-950);
    font-weight: 600; font-size: 0.88rem; padding: 12px 28px;
    border-radius: var(--r-2); text-decoration: none;
    transition: background var(--dur-1) var(--ease-out);
  }
  .article-newsletter-btn:hover { background: #E5CE96; }
  .article-newsletter-btn:active { transform: scale(var(--btn-active-scale)); }

  /* ── Related ── */
  .article-related {
    max-width: var(--max-width);
    margin: 64px auto 0;
    padding-top: 48px;
    border-top: 1px solid var(--hairline);
  }
  .article-related-header {
    text-align: center;
    margin-bottom: 28px;
  }
  .article-related-kicker {
    font-family: var(--font-ui);
    font-weight: 600; font-size: 0.64rem; letter-spacing: 0.16em;
    color: var(--accent-text); text-transform: uppercase;
    display: block; margin-bottom: 6px;
  }
  .article-related-heading {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--text);
    font-weight: 500;
    text-align: center;
    letter-spacing: -0.01em;
  }
  .article-related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--gap);
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .article-related-grid { grid-template-columns: repeat(2, 1fr); }
    .article-share-rail { display: none; }
    .article-body-grid { gap: 0; }
  }

  @media (max-width: 640px) {
    .article-page { padding: 16px 16px 48px; }
    .article-hero-figure { margin-bottom: 20px; }
    .article-headline { font-size: clamp(1.5rem, 6vw, 2rem); }
    .article-standfirst { font-size: 1rem; }
    .article-prose { font-size: 1rem; line-height: 1.68; }
    .article-related-grid { grid-template-columns: 1fr; }
    .article-related { margin-top: 48px; padding-top: 32px; }
    .reading-progress { height: 2px; }
  }
</style>
