---
import Base from "./Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import ArticleCard from "../components/ArticleCard.astro";
import AffiliateBanner from "../components/AffiliateBanner.astro";
import BreadcrumbBar from "../components/BreadcrumbBar.astro";
import Icons from "../components/Icons.astro";
import { marked } from "marked";

export interface RelatedPost {
  title: string;
  slug: string;
  excerpt: string;
  image: string;
  tags: string[];
  date: string;
}

export interface Props {
  title: string;
  slug: string;
  date: string;
  region: string;
  excerpt: string;
  image: string;
  tags: string[];
  body: string;
  author?: string;
  related?: RelatedPost[];
}

const {
  title,
  slug,
  date,
  region,
  excerpt,
  image,
  tags = [],
  body = "",
  author = "The Ganja Club",
  related = [],
} = Astro.props;

/* Convert markdown body to HTML — handles both pure markdown and inline HTML */
const htmlBody = marked.parse(body, { breaks: true });

const siteUrl = "https://theganjaclub.co.uk";
const postUrl = `${siteUrl}/post/${slug}`;

/* Absolute image URL for structured data / OG tags */
const fullImage = image
  ? (image.startsWith("http") ? image : `${siteUrl}${image}`)
  : `${siteUrl}/images/flower/pexels-kindelmedia-7667912.webp`;

/* Display image src — works in dev and prod */
const heroSrc = image.startsWith("http") ? image : image;

/* Reading time — strip HTML, count words, ~225 wpm */
const wordCount = (htmlBody || "")
  .replace(/<[^>]*>/g, " ")
  .split(/\s+/)
  .filter(Boolean)
  .length;
const readingTime = Math.max(1, Math.ceil(wordCount / 225));

/* Region display */
const regionMap: Record<string, string> = {
  uk: "UK",
  europe: "Europe",
  usa: "USA",
  global: "Global",
  Research: "Research",
};
const regionLabel = regionMap[region] || "News";
const backRegionLabel = region === "global" ? "World" : regionLabel;
const regionUrl = region === "Research" ? "/research" : `/${region}`;

/* Tag → URL mapping: region tags route to region pages, topic tags to /guides */
const regionTagMap: Record<string, string> = {
  uk: "/uk",
  europe: "/europe",
  usa: "/usa",
  global: "/global",
  research: "/research",
};
function tagUrl(tag: string): string {
  const lower = tag.toLowerCase();
  if (lower in regionTagMap) return regionTagMap[lower];
  return `/guides?tag=${encodeURIComponent(tag)}`;
}

/* Author display name */
const authorDisplay = author || "The Ganja Club";
const authorInitials = authorDisplay === "The Ganja Club" ? "TGC" : authorDisplay.split(" ").map((w: string) => w[0]).join("").slice(0, 3).toUpperCase();

/* Formatted date */
const dateObj = new Date(date);
const formattedDate = dateObj.toLocaleDateString("en-GB", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
const kickerText = `${regionLabel} · ${formattedDate.toUpperCase()}`;

/* JSON-LD: Article schema */
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description: excerpt,
  image: [fullImage],
  datePublished: date,
  dateModified: date,
  author: { "@type": "Organization", name: "The Ganja Club", url: siteUrl },
  publisher: {
    "@type": "Organization",
    name: "The Ganja Club",
    url: siteUrl,
    logo: { "@type": "ImageObject", url: `${siteUrl}/logo.svg` },
  },
  mainEntityOfPage: { "@type": "WebPage", "@id": postUrl },
};

/* JSON-LD: Breadcrumb */
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
    { "@type": "ListItem", position: 2, name: regionLabel, item: `${siteUrl}${regionUrl}` },
    { "@type": "ListItem", position: 3, name: title, item: postUrl },
  ],
};
---

<Base
  title={`${title} — The Ganja Club`}
  description={excerpt}
  ogImage={image}
  ogType="article"
  canonicalUrl={postUrl}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} is:inline />

  <div class="reading-progress" aria-hidden="true"><div class="reading-progress-bar"></div></div>

  <AffiliateBanner />
  <Nav />
  <BreadcrumbBar region={region} title={title} />

  <main id="main-content">
    <article class="article-page">
      <a href={regionUrl} class="article-back-link">
        <Icons name="arrow-left" />
        Back to {backRegionLabel} News
      </a>

      <!-- Hero -->
      <header class="article-hero-section">
        <div class="article-hero-img-wrap">
          <img
            src={heroSrc}
            alt={title}
            class="article-hero-img"
            width="1200"
            height="675"
            loading="eager"
            decoding="async" />
        </div>

        <div class="article-hero-text">
          <div class="article-kicker-line">{kickerText}</div>
          <h1 class="article-headline">{title}</h1>
          <p class="article-standfirst">{excerpt}</p>
          <div class="article-author-byline">
            <span class="author-rule" aria-hidden="true"></span>
            <span class="author-text">By {authorDisplay}</span>
          </div>
          <div class="article-byline">
            <time datetime={dateObj.toISOString()}>{formattedDate}</time>
            <span class="byline-dot" aria-hidden="true">·</span>
            <span>{readingTime} min read</span>
          </div>
        </div>
      </header>

      <!-- Body: sticky share rail + prose -->
      <div class="article-body-grid">
        <aside class="article-share-rail" aria-label="Share this article">
          <span class="share-rail-label">Share</span>
          <a
            href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(postUrl)}`}
            target="_blank"
            rel="noopener"
            class="share-rail-btn"
            aria-label="Share on X">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <button class="share-rail-btn" data-share="copy" aria-label="Copy link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
              <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
            </svg>
          </button>
        </aside>

        <div class="article-prose" set:html={htmlBody} />
      </div>

      <!-- Tag pills -->
      {tags.length > 0 && (
        <div class="article-tags-bar">
          {tags.map((tag: string) => (
            <a href={tagUrl(tag)} class="tag-pill">{tag}</a>
          ))}
        </div>
      )}

      <!-- Newsletter CTA -->
      <section class="article-newsletter-cta">
        <div class="article-newsletter-inner">
          <span class="article-newsletter-kicker">STAY INFORMED</span>
          <h3>Get the daily briefing in your inbox</h3>
          <p>UK medical cannabis news, policy changes and patient resources — delivered daily, free.</p>
          <a href="/#newsletter" class="article-newsletter-btn">Subscribe <Icons name="arrow-right" /></a>
        </div>
      </section>

      <!-- Related articles -->
      {related.length > 0 && (
        <section class="article-related">
          <div class="article-related-header">
            <span class="article-related-kicker">MORE TO READ</span>
            <h2 class="article-related-heading">Read Next</h2>
          </div>
          <div class="article-related-grid">
            {related.map((p: RelatedPost) => (
              <ArticleCard
                title={p.title}
                slug={p.slug}
                excerpt={p.excerpt}
                image={p.image}
                tags={p.tags}
                date={p.date}
              />
            ))}
          </div>
        </section>
      )}
    </article>
  </main>

  <Footer />

  <script>
    const copyBtn = document.querySelector<HTMLButtonElement>('[data-share="copy"]');
    if (copyBtn) {
      const originalSvg = copyBtn.querySelector('svg')?.innerHTML || '';
      copyBtn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(window.location.href);
          copyBtn.classList.add('copied');
          const svg = copyBtn.querySelector('svg');
          if (svg) {
            svg.innerHTML = '<path d="M20 6L9 17l-5-5" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>';
          }
          setTimeout(() => {
            copyBtn.classList.remove('copied');
            if (svg) svg.innerHTML = originalSvg;
          }, 2000);
        } catch {
          /* Clipboard API unavailable — silently fail */
        }
      });
    }
  </script>

  <script>
    // Reading progress bar — transforms scaleX based on scroll position
    const progressBar = document.querySelector<HTMLElement>('.reading-progress-bar');
    if (progressBar) {
      let ticking = false;
      function updateProgress() {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = docHeight > 0 ? Math.min(scrollTop / docHeight, 1) : 0;
        progressBar.style.transform = `scaleX(${progress})`;
        ticking = false;
      }
      window.addEventListener('scroll', () => {
        if (!ticking) {
          window.requestAnimationFrame(updateProgress);
          ticking = true;
        }
      }, { passive: true });
      updateProgress();
    }
  </script>
</Base>

<style>
  /* ═══════════════════════════════════════════════
     Article Page — Editorial Layout
     Monocle-inspired · Lora + Inter · TGC Design System
     ═══════════════════════════════════════════════ */

  .article-page {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 24px 24px 64px;
  }

  /* ── Hero ── */
  .article-hero-section { margin-bottom: 48px; }

  .article-hero-img-wrap {
    width: 100%;
    max-width: 960px;
    margin: 0 auto 32px;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: var(--radius);
    box-shadow: var(--shadow-lg);
  }
  .article-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .article-hero-text {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 8px;
  }
  .article-kicker-line {
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--green);
    margin-bottom: 12px;
  }
  .article-headline {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.12;
    color: var(--green);
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-bottom: 16px;
  }
  .article-standfirst {
    font-family: var(--font-body);
    font-size: 1.15rem;
    line-height: 1.6;
    color: var(--text-secondary);
    letter-spacing: -0.01em;
    margin-bottom: 20px;
  }
  .article-byline {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.82rem;
    color: var(--text-muted);
    font-weight: 500;
    letter-spacing: 0.02em;
  }
  .byline-dot { opacity: 0.5; }

  /* ── Reading Progress Bar ── */
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    z-index: 9999;
    pointer-events: none;
    background: transparent;
  }
  .reading-progress-bar {
    width: 100%;
    height: 100%;
    transform: scaleX(0);
    transform-origin: left center;
    background: linear-gradient(90deg, var(--green-accent), var(--green));
    transition: transform 0.15s ease-out;
  }

  /* ── Author Byline ── */
  .article-author-byline {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
  }
  .author-rule {
    display: inline-block;
    width: 24px;
    height: 1px;
    background: var(--border);
    flex-shrink: 0;
  }
  .author-text {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--text-muted);
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  /* ── Body Grid: share rail + prose ── */
  .article-body-grid {
    display: flex;
    gap: 40px;
    justify-content: center;
    max-width: 820px;
    margin: 0 auto;
  }

  /* ── Share Rail (sticky, desktop only) ── */
  .article-share-rail {
    position: sticky;
    top: calc(var(--banner-height) + var(--nav-height) + 44px);
    align-self: flex-start;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }
  .share-rail-label {
    font-family: var(--font-body);
    font-size: 0.6rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    writing-mode: vertical-rl;
    text-orientation: mixed;
    margin-bottom: 8px;
  }
  .share-rail-btn {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-circle);
    border: 1px solid var(--border);
    background: var(--bg-card);
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.18s ease, color 0.18s ease, border-color 0.18s ease,
                transform 0.18s ease;
    box-shadow: var(--shadow);
  }
  .share-rail-btn:hover {
    background: var(--green);
    color: var(--text-on-dark);
    border-color: var(--green);
    transform: translateY(-2px);
  }
  .share-rail-btn:active { transform: scale(var(--btn-active-scale)); }
  .share-rail-btn.copied {
    background: var(--green-accent);
    color: var(--text-on-dark);
    border-color: var(--green-accent);
  }

  /* ── Article Prose ── */
  .article-prose {
    max-width: 720px;
    width: 100%;
    font-family: var(--font-body);
    font-size: 1.125rem;          /* 18px */
    line-height: 1.7;
    color: var(--text);
    letter-spacing: -0.01em;
  }

  /* Drop cap on first paragraph */
  .article-prose :global(p:first-of-type)::first-letter {
    font-family: var(--font-display);
    font-size: 3.5em;
    line-height: 0.8;
    float: left;
    margin: 0.05em 0.08em 0 0;
    color: var(--green);
    font-weight: 600;
  }

  .article-prose :global(p) { margin-bottom: 1.4rem; }
  .article-prose :global(h2) {
    font-family: var(--font-display);
    font-size: 1.6rem;
    line-height: 1.2;
    color: var(--green);
    margin: 2.5rem 0 1rem;
    font-weight: 600;
  }
  .article-prose :global(h3) {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--text);
    margin: 2rem 0 0.75rem;
    font-weight: 600;
  }
  .article-prose :global(blockquote) {
    border-left: 4px solid var(--gold);
    padding: 1rem 0 1rem 2rem;
    margin: 2rem 0;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    color: var(--text);
    font-size: 1.3rem;
    line-height: 1.5;
    letter-spacing: -0.01em;
  }
  .article-prose :global(blockquote p) { margin-bottom: 0; }
  .article-prose :global(ul),
  .article-prose :global(ol) {
    margin: 1rem 0 1.4rem 1.5rem;
  }
  .article-prose :global(li) { margin-bottom: 0.5rem; }
  .article-prose :global(strong) { color: var(--text); font-weight: 700; }
  .article-prose :global(a) {
    color: var(--green-accent);
    text-decoration: none;
    border-bottom: 1px solid var(--green-accent);
    transition: border-color 0.15s ease;
  }
  .article-prose :global(a:hover) { border-bottom-color: var(--green); }
  .article-prose :global(hr) {
    border: none;
    border-top: 2px solid var(--border);
    margin: 2.5rem 0;
  }
  .article-prose :global(img) {
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    margin: 1.5rem 0;
  }

  /* ── Tag Pills ── */
  .article-tags-bar {
    max-width: 720px;
    margin: 48px auto 0;
    padding-top: 32px;
    border-top: 1px solid var(--border);
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .tag-pill {
    display: inline-block;
    padding: 6px 16px;
    border: 1.5px solid var(--green);
    border-radius: var(--radius);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--green);
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: background 0.18s ease, color 0.18s ease, transform 0.18s ease;
  }
  .tag-pill:hover {
    background: var(--green);
    color: var(--text-on-dark);
  }
  .tag-pill:active { transform: scale(var(--btn-active-scale)); }

  /* ── Related ── */
  .article-related {
    max-width: var(--max-width);
    margin: 64px auto 0;
    padding-top: 48px;
    border-top: 2px solid var(--border);
  }
  .article-related-heading {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--green);
    margin-bottom: 24px;
    font-weight: 600;
    text-align: center;
    letter-spacing: -0.01em;
  }
  .article-related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--gap);
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .article-related-grid { grid-template-columns: repeat(2, 1fr); }
    .article-share-rail { display: none; }
    .article-body-grid { gap: 0; }
  }

  @media (max-width: 640px) {
    .article-page { padding: 16px 16px 48px; }
    .article-hero-img-wrap { border-radius: 8px; margin-bottom: 24px; }
    .article-headline { font-size: clamp(1.5rem, 6vw, 2rem); }
    .article-standfirst { font-size: 1rem; }
    .article-prose { font-size: 1rem; line-height: 1.65; }
    .article-prose :global(p:first-of-type)::first-letter { font-size: 3em; }
    .article-prose :global(h2) { font-size: 1.35rem; }
    .article-related-grid { grid-template-columns: 1fr; }
    .article-related { margin-top: 48px; padding-top: 32px; }
    .reading-progress { height: 2px; }
  }

  /* ── Dark mode overrides — brand green night theme ──
     :global() wraps [data-theme="dark"] so Astro doesn't scope it
     to the component — data-theme lives on <html>, not our elements */
  :global([data-theme="dark"]) .article-headline { color: #e8f2ed; }
  :global([data-theme="dark"]) .article-kicker-line { color: #4dab8a; }
  :global([data-theme="dark"]) .article-prose :global(h2) { color: #e8f2ed; }
  :global([data-theme="dark"]) .article-prose :global(h3) { color: #d4e9e2; }
  :global([data-theme="dark"]) .article-prose :global(p:first-of-type)::first-letter { color: var(--green-light); }
  :global([data-theme="dark"]) .article-prose :global(a) {
    color: #4dab8a;
    border-bottom-color: #4dab8a;
  }
  :global([data-theme="dark"]) .article-prose :global(a:hover) { border-bottom-color: #d4e9e2; }
  :global([data-theme="dark"]) .article-prose :global(blockquote) { border-left-color: #cba258; }
  :global([data-theme="dark"]) .article-prose :global(code) {
    background: #0F1E19;
    color: #d4e9e2;
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.9em;
  }
  :global([data-theme="dark"]) .article-prose :global(pre) {
    background: #0F1E19;
    border: 1px solid rgba(212, 233, 226, 0.12);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    overflow-x: auto;
  }
  :global([data-theme="dark"]) .article-prose :global(pre code) {
    background: none;
    padding: 0;
  }
  :global([data-theme="dark"]) .tag-pill {
    border-color: var(--green);
    color: var(--green-light);
  }
  :global([data-theme="dark"]) .tag-pill:hover {
    background: var(--green);
    color: var(--text-on-dark);
  }
  :global([data-theme="dark"]) .article-related-heading { color: #e8f2ed; }
  :global([data-theme="dark"]) .author-text { color: rgba(163,196,184,0.5); }
  :global([data-theme="dark"]) .author-rule { background: rgba(212,233,226,0.12); }
  :global([data-theme="dark"]) .share-rail-btn {
    background: var(--green-light);
    color: #122620;
    border-color: var(--green-light);
  }
  :global([data-theme="dark"]) .share-rail-btn:hover {
    background: var(--green);
    border-color: var(--green);
    color: var(--text-on-dark);
  }

  /* ── Newsletter CTA (inline, after article body) ── */
  .article-newsletter-cta {
    max-width: 720px;
    margin: 48px auto 0;
  }
  .article-newsletter-inner {
    background: var(--green-house);
    border-radius: var(--radius);
    padding: 36px 32px;
    text-align: center;
  }
  .article-newsletter-kicker {
    font-weight: 700; font-size: 0.62rem; letter-spacing: 0.16em;
    color: var(--gold); text-transform: uppercase;
    display: block; margin-bottom: 10px;
  }
  .article-newsletter-inner h3 {
    font-family: var(--font-display); font-size: 1.4rem; font-weight: 600;
    color: var(--text-on-dark); margin-bottom: 10px; letter-spacing: -0.01em;
  }
  .article-newsletter-inner p {
    font-size: 0.92rem; line-height: 1.55; color: var(--text-on-dark-soft);
    margin-bottom: 20px; max-width: 420px; margin-left: auto; margin-right: auto;
  }
  .article-newsletter-btn {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--green-accent); color: var(--text-on-dark);
    font-weight: 600; font-size: 0.9rem; padding: 12px 28px;
    border-radius: var(--radius-btn); text-decoration: none;
    transition: background 0.15s ease, transform 0.15s ease;
