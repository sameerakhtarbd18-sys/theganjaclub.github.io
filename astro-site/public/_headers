# Cloudflare Pages headers — replaces the [[headers]] blocks in netlify.toml
# Lives in public/ so Astro copies it into dist/ at build time.

/images/*
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/*.html
  Cache-Control: public, max-age=3600
